exports[`Help snapshots — contract stability > help for ib bug list matches snapshot 1`] = `
"USAGE
  ib bug list [flags]

DESCRIPTION
  List bug reports. Permission-filtered server-side: a regular user sees their own + their company's reports; an admin/developer sees all and may narrow by --owner (ownerAsiakasId; ignored for non-admins). Newest first by default.
  Auth: requires login (any authenticated user).

FLAGS
  --status STRING    new | in-progress | resolved | closed
  --severity STRING    critical | major | minor | cosmetic
  --type STRING    ui-display-issue | functionality-error | performance-problem | data-incorrect | other
  --owner NUMBER    Filter by owning tenant asiakasId (admins only)
  --limit NUMBER    Max rows (sets truncated when hit)
  --offset NUMBER    Pagination offset
  --order-by STRING    createdAt | updatedAt | severity | status | bugType | bugReportId (default: createdAt)
  --order STRING    asc | desc (default: desc)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { items: BugReportRow[], nextCursor: null, count, truncated } (+truncated:true when the result hit the limit; backend ≥ 2026-06-11)

ERRORS (stderr, exit non-zero)
  exit 4  Validation             → --status/--severity/--type/--order-by/--order must be valid enum values
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

SEE ALSO
  ib bug get, ib bug admin stats

EXAMPLES
  ib bug list --status new --severity major
  ib bug list --owner 1349 --limit 20
"
`;

exports[`Help snapshots — contract stability > help for ib cache clear matches snapshot 1`] = `
"USAGE
  ib cache clear [flags]

DESCRIPTION
  Flush the entire Redis cache (curated sweep; preserves sessions/locks/metrics). Previews (X-Dry-Run) unless --confirm. Cross-tenant: clears every company's cached data. Guard: refuses deployed endpoints unless --force-prod. Developer-only.
  Permissions: requires isSystemAdmin or isDeveloper.

FLAGS
  --confirm BOOLEAN    Execute the operation (default is dry-run preview)
  --force-prod BOOLEAN    Execute against a deployed (shared-cache) backend. Sent as X-Force-Prod: 1; a deployed backend refuses destructive cache ops without it (403) — including calls routed via /api/cli/exec and MCP ib_exec.
  --reason STRING    Audit reason (X-Action-Reason)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  preview: { dryRun:true, wouldDelete } | execute: { deleted }

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Not a developer        → requires isSystemAdmin or isDeveloper
  exit 6 (HTTP 500)  Backend error          → retry with --verbose
  exit 3  Refused: deployed endpoint without --force-prod → prod and staging share Redis DB 3; add --force-prod or use a local endpoint
  exit 3  Blocked by read-only mode → executing a cache write needs --confirm and a session without --read-only/IB_READ_ONLY (previews still work)

EXAMPLES
  ib cache clear
  ib cache clear --confirm --force-prod
"
`;

exports[`Help snapshots — contract stability > help for ib cache entities matches snapshot 1`] = `
"USAGE
  ib cache entities [flags]

DESCRIPTION
  List the valid cache entity types, their scope params (id/asiakasId), cascade support, and example invalidation commands. Offline — no auth required.
  Auth: none (public).

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { items: [{ entityType, params[], cascade?, developerOnly?, example }], count }

ERRORS (stderr, exit non-zero)
  exit 0  Always succeeds (offline static list) → n/a

EXAMPLES
  ib cache entities
"
`;

exports[`Help snapshots — contract stability > help for ib cache invalidate matches snapshot 1`] = `
"USAGE
  ib cache invalidate <entityType> [flags]

DESCRIPTION
  Invalidate cache for one entity family by domain identifier (no Redis key knowledge needed). Previews (X-Dry-Run) unless --confirm. --cascade fans out to related families (keikka only). Any admin; non-developers are scoped to their own company. Guard: refuses deployed endpoints unless --force-prod (all slots share Redis DB 3).
  Permissions: requires admin role (SystemAdmin, AsiakasAdmin, or LaskuAdmin) or developer.

ARGUMENTS
  <entityType> STRING    Entity family, e.g. keikka/asiakas/vehicle (see \`ib cache entities\`) (required)

FLAGS
  --id NUMBER    Entity id (e.g. keikkaId)
  --asiakas-id NUMBER    Tenant scope (developers may target others; non-devs use their own)
  --cascade BOOLEAN    Also invalidate related families (keikka only)
  --confirm BOOLEAN    Execute the operation (default is dry-run preview)
  --force-prod BOOLEAN    Execute against a deployed (shared-cache) backend. Sent as X-Force-Prod: 1; a deployed backend refuses destructive cache ops without it (403) — including calls routed via /api/cli/exec and MCP ib_exec.
  --reason STRING    Audit reason (X-Action-Reason)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  preview: { dryRun:true, wouldDelete, patterns[] } | execute: { dryRun:false, deleted }

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Unknown entityType or cascade unsupported → run \`ib cache entities\` to list valid types
  exit 3 (HTTP 403)  Not an admin, or cross-tenant entity needs developer → cross-tenant entities (keikka, grid, stat, attachment) require isSystemAdmin/isDeveloper; others need an admin role
  exit 3  Refused: deployed endpoint without --force-prod → prod and staging share Redis DB 3; add --force-prod or use a local endpoint
  exit 3  Blocked by read-only mode → executing a cache write needs --confirm and a session without --read-only/IB_READ_ONLY (previews still work)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Without --confirm the command only PREVIEWS (counts keys) and never deletes.
  - Single-entity invalidate may leave related caches (grid/stepLog/attachments) stale — use --cascade (keikka) or invalidate each family.

SEE ALSO
  ib cache entities, ib cache keys

EXAMPLES
  ib cache invalidate keikka --id 123
  ib cache invalidate keikka --id 123 --cascade --confirm
  ib cache invalidate asiakas --asiakas-id 8 --confirm
"
`;

exports[`Help snapshots — contract stability > help for ib cache keys matches snapshot 1`] = `
"USAGE
  ib cache keys [flags]

DESCRIPTION
  Key counts grouped by prefix pattern (SCAN). Developer-only.
  Permissions: requires isSystemAdmin or isDeveloper.

FLAGS
  --pattern STRING    SCAN match glob (default: *) (default: *)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
