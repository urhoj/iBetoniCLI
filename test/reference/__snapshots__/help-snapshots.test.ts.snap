exports[`Help snapshots — contract stability > help for ib person list matches snapshot 1`] = `
"USAGE
  ib person list [flags]

DESCRIPTION
  List the active company's persons. By DEFAULT returns its MEMBERS (the asiakasPerson attachment — the same set as \`ib customer person list\`); --owned returns the persons it OWNS (person.ownerAsiakasId) instead. --asiakas <id> scopes to the MEMBERS of another company you belong to (member-gated). Optional --role uses ROLE_NAME_BY_TYPEID from @ibetoni/constants.
  Permissions: requires auth.page.person.read.

FLAGS
  --role STRING    Filter by role name (e.g. driver, admin, laskuAdmin)
  --asiakas NUMBER    Scope to the MEMBERS of this asiakasId instead of the active company (you must belong to it). Combine with --owned for the persons it owns.
  --owned BOOLEAN    List persons the company OWNS (person.ownerAsiakasId) instead of its asiakasPerson members (the default).
  --limit NUMBER    Max rows (capped at 500) (default: 100)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  ListEnvelope<{ personId, name, email, roles:number[] }> (+truncated:true when the result hit the limit; backend ≥ 2026-06-11)

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Unknown role           → use a role from @ibetoni/constants ROLE_TYPEID_BY_NAME
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.person.read
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib person list
  ib person list --owned
  ib person list --asiakas 1349 --limit 50
"
`;

exports[`Help snapshots — contract stability > help for ib person log matches snapshot 1`] = `
"USAGE
  ib person log <personId> [flags]

DESCRIPTION
  Change-tracker audit trail for one person — who changed what, when, with the \`--reason\` recorded by every write. INCLUDES role grants/revokes (fieldName 'asiakasPersonSetting', e.g. 'Rooli lisätty: asiakasAdmin (Asiakas Admin)'); pass \`--field asiakasPersonSetting\` to see only role changes. GET /api/changes/person/:personId/:ownerAsiakasId; owner defaults to the active company. --field filters client-side.
  Auth: requires login (any authenticated user).

ARGUMENTS
  <personId> NUMBER    personId whose audit trail to fetch (required)

FLAGS
  --owner NUMBER    ownerAsiakasId (default: active company)
  --limit NUMBER    Max rows (capped at 500) (default: 100)
  --field STRING    Filter by changeTracker fieldName (e.g. asiakasPersonSetting for role changes)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  ListEnvelope<{ changeId, field, oldValue, newValue, changeType, personId, personName, at, description, reason }>

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Not a member of that company (and not admin) → ib company switch to that owner, or use an admin token
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib person log 63
  ib person log 63 --field asiakasPersonSetting
  ib person log 63 --owner 27 --limit 50
"
`;

exports[`Help snapshots — contract stability > help for ib person me matches snapshot 1`] = `
"USAGE
  ib person me [flags]

DESCRIPTION
  Your own profile, your roles aggregated across all your companies, and the companies you can act on. Derives identity from the JWT (works with IB_TOKEN). For the roles scoped to a single company, use \`person role list --asiakas\`.
  Auth: requires login (any authenticated user).

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { personId, name, email, phone, activeCompany:{asiakasId,name}, tier:'developer'|'admin'|'standard', roles:[{roleTypeId,role}], companies:[{asiakasId,name,current}], impersonating?:{actorPersonId,sessionId} } — \`tier\` is the capability/discovery gate (the MCP-reachable equivalent of \`auth whoami\`'s tier); \`impersonating\` present only when acting as another person.

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib person me
  ib person me --pretty
"
`;

exports[`Help snapshots — contract stability > help for ib person notify matches snapshot 1`] = `
"USAGE
  ib person notify <person> [flags]

DESCRIPTION
  Send an FCM push to a person — ergonomic alias for \`ib notification fcm send --person <person>\`. Admin/HR-gated. <person> is a personId or a name resolved within your company. --dry-run previews recipient + device count.
  Permissions: requires company admin (isAsiakasAdmin) or HR admin (isHRAdmin) on the active company, or global sysadmin (server-enforced).

ARGUMENTS
  <person> STRING    Recipient personId, or a name resolved within your company (required)

FLAGS
  --title STRING    Notification title (required)
  --body STRING    Notification body (required)
  --data STRING    Extra FCM data payload as a JSON object

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  Same as \`ib notification fcm send\` (delegates to it).

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Missing/invalid field (no --title/--body, ambiguous name, non-object --data) → supply --title/--body and an unambiguous person
  exit 3 (HTTP 403)  Not Admin/HR on the active company → switch to a company where you are admin/HR
  exit 5 (HTTP 404)  Recipient not found in your company → check the personId / name
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Thin alias — same gate, name resolution, and output as \`ib notification fcm send\`. Deploy-gated.

SEE ALSO
  ib notification fcm send

EXAMPLES
  ib person notify 6233 --title 'Keikka siirretty' --body 'Alkaa klo 8'
  ib person notify 'Juha Urho' --title Muistutus --body Tarkista --dry-run
"
`;

exports[`Help snapshots — contract stability > help for ib person owner matches snapshot 1`] = `
"USAGE
  ib person owner <personId> [flags]

DESCRIPTION
  Set or clear a person's owner company (ownerAsiakasId). Provide EXACTLY ONE of --global (make the person GLOBAL/self-managing, ownerAsiakasId=null, discoverable across companies) or --asiakas <id> (assign/move ownership). This is SEPARATE from roles — a global person can still hold roles via \`ib person role grant\`, and from membership via \`ib customer person add\`. Requires --reason.
  Permissions: requires developer/system-admin: any person → any target, self (your own personId): → null always; → a company only if you are a member of it, company-admin: may release a person CURRENTLY owned by your company → global (cannot pull others in).

ARGUMENTS
  <personId> NUMBER    personId whose owner to change (required)

FLAGS
  --global BOOLEAN    Make the person global (ownerAsiakasId=null)
  --asiakas NUMBER    Set owner to this asiakasId
  --reason STRING    Audit-log reason (X-Action-Reason); REQUIRED

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { personId, ownerAsiakasId } or { dryRun: true, wouldSetOwner: { personId, from, to } }

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Not allowed to change this person's owner → see the authz rules above (developer/self/company-admin)
  exit 5 (HTTP 404)  Person not found       → verify personId
  exit 4  Bad flags              → provide exactly one of --global / --asiakas and a --reason

EXAMPLES
  ib person owner 5351 --global --reason 'make self-managing'
  ib person owner 5351 --asiakas 26 --reason 'assign to company 26'
  ib person owner 5351 --global --reason preview --dry-run
"
`;

exports[`Help snapshots — contract stability > help for ib person role explain matches snapshot 1`] = `
"USAGE
  ib person role explain <name> [flags]

DESCRIPTION
  Explain a role NAME: its asiakasPersonSettingTypeId, human display name, the access tiers it grants (anyAdmin/anyWorker/anyViewer/laskuRead/requestOffer/adminCompanySelection), and whether it is deprecated — all from @ibetoni/constants. Enriched with the LIVE DB \`description\` (internal flag name, e.g. isAsiakasAdmin) and \`comment\` (rich Finnish text) read from GET /api/asiakasPersonSettings/getAllTypes, so the prose never drifts from dbo.asiakasPersonSettingTypes. Requires auth (any logged-in user); description/comment are null for roles the endpoint omits (soft-deleted pumppuHandler/Viewer). Use it to disambiguate the role names accepted by \`person role grant/revoke\` and \`customer person list --role\`.
  Auth: requires login (any authenticated user).

ARGUMENTS
  <name> STRING    role name (e.g. asiakasAdmin, keikkaHandler, lomaseurannassa) (required)

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { role, typeId, displayName: string|null, description: string|null, comment: string|null, tiers: string[], deprecated: boolean }

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Unknown role name      → see ROLE_TYPEID_BY_NAME in @ibetoni/constants
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

SEE ALSO
  ib person role grant, ib person role revoke, ib customer person list

EXAMPLES
  ib person role explain asiakasAdmin
  ib person role explain lomaseurannassa
"
`;

exports[`Help snapshots — contract stability > help for ib person role grant matches snapshot 1`] = `
"USAGE
  ib person role grant <personId> [flags]

DESCRIPTION
  Grant a per-company role to a person. POST /api/asiakasPersonSettings/add/:asiakasId/:personId/:roleTypeId. Admin-gated on the tenant (tier depends on the role). --dry-run previews via the backend ({ dryRun:true, wouldCreate }).
  Permissions: requires company admin on the target tenant (tier per role).

ARGUMENTS
  <personId> NUMBER    personId (required)

FLAGS
  --role STRING    Role name (REQUIRED), e.g. keikkaHandler, vehicleHandler, hrAdmin
  --asiakas NUMBER    Target asiakasId (REQUIRED)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { granted: { personId, asiakasId, roleTypeId } } | { dryRun:true, wouldCreate:{ personId, asiakasId, personSettingTypeId, personSettingString }, validation }

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Unknown role / company limit reached → use a name from ROLE_TYPEID_BY_NAME
  exit 3 (HTTP 403)  Not a tenant admin     → use a system-admin token or a tenant admin
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib person role grant 5351 --role keikkaHandler --asiakas 26 --reason 'onboard handler'
  ib person role grant 5351 --role vehicleHandler --asiakas 26 --reason preview --dry-run
"
`;

