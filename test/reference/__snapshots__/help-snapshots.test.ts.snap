exports[`Help snapshots — contract stability > help for ib message support contact matches snapshot 1`] = `
"USAGE
  ib message support contact [flags]

DESCRIPTION
  Open (or append to) a support thread escalating a tarjous (pumppuRequest) or keikka to the platform. Any authenticated user. A REAL write — honours the read-only write-lock. --dry-run resolves CLIENT-SIDE (prints the payload, never POSTs). Reply later with \`ib message chat send <threadId> --body ...\`.
  Auth: requires login (any authenticated user).

FLAGS
  --tarjous NUMBER    pumppuRequestId this escalation is about
  --keikka NUMBER    keikkaId this escalation is about
  --body STRING    The message to support (required)
  --dry-run BOOLEAN    Print the payload without sending (client-side)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { threadId, message } on success. With --dry-run: { dryRun:true, wouldSend:{ method, path, body } }.

ERRORS (stderr, exit non-zero)
  exit 4  Validation             → Provide exactly one of --keikka / --tarjous (positive integer) and a non-empty --body
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Exactly one of --keikka / --tarjous selects the context; --keikka wins if both are passed.
  - reply with: ib message chat send <threadId> --body ...

SEE ALSO
  ib message chat send, ib message support inbox

EXAMPLES
  ib message support contact --tarjous 23 --body "Provider not responding — please intervene"
  ib message support contact --keikka 5012 --body "Wrong worksite assigned" --dry-run
"
`;

exports[`Help snapshots — contract stability > help for ib message support inbox matches snapshot 1`] = `
"USAGE
  ib message support inbox [flags]

DESCRIPTION
  Support triage queue: support threads escalated by operators, newest first. Developer-only (isSystemAdmin / isDeveloper). Filter by lifecycle status. Projects GET /api/messages/support/inbox into the list envelope.
  Permissions: requires isSystemAdmin or isDeveloper.

FLAGS
  --status STRING    open | resolved | all (default: open)
  --limit NUMBER    Max rows

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { items: SupportThreadRow[], nextCursor: null, count, truncated }

ERRORS (stderr, exit non-zero)
  exit 4  Validation             → --status must be open|resolved|all
  exit 3 (HTTP 403)  Permission denied      → requires a developer token (isSystemAdmin/isDeveloper)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Read a thread's messages with \`ib message chat list <threadId>\` and reply with \`ib message chat send <threadId> --body ...\` (a support thread is a normal messageThread admins can read).

SEE ALSO
  ib message chat list, ib message support resolve

EXAMPLES
  ib message support inbox
  ib message support inbox --status all --limit 50
"
`;

exports[`Help snapshots — contract stability > help for ib message support mine matches snapshot 1`] = `
"USAGE
  ib message support mine [flags]

DESCRIPTION
  Your own company's support threads (audience='support', owned by your active company), newest first. The operator-facing companion to the developer-only inbox — any member of the owning company may list them. Filter by lifecycle status. Projects GET /api/messages/support/mine into the list envelope; each row carries a caller-scoped unreadCount.

FLAGS
  --status STRING    open | resolved | all (default: open)
  --limit NUMBER    Max rows

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { items: SupportThreadRow[], nextCursor: null, count, truncated }

ERRORS (stderr, exit non-zero)
  exit 4  Validation             → --status must be open|resolved|all
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 5 (HTTP 404)  Route not deployed     → the /support/mine backend may not be deployed yet
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Read a thread's messages with \`ib message chat list <threadId>\` and reply with \`ib message chat send <threadId> --body ...\`. Open (or append to) a new escalation with \`ib message support contact\`.

SEE ALSO
  ib message support contact, ib message chat list

EXAMPLES
  ib message support mine
  ib message support mine --status all --limit 50
"
`;

exports[`Help snapshots — contract stability > help for ib message support resolve matches snapshot 1`] = `
"USAGE
  ib message support resolve <threadId> [flags]

DESCRIPTION
  Mark a support thread resolved, or --reopen it back to open. Developer-only (isSystemAdmin / isDeveloper). A REAL write (PATCH) — blocked under --read-only (exit 3). --dry-run previews the body client-side without sending.
  Permissions: requires isSystemAdmin or isDeveloper.

ARGUMENTS
  <threadId> NUMBER    support messageThread id (required)

FLAGS
  --reopen BOOLEAN    Set status back to open instead of resolved
  --dry-run BOOLEAN    Print the update body without sending (client-side)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { threadId, status } on success. With --dry-run: { dryRun:true, wouldSend:{ method, path, body } }.

ERRORS (stderr, exit non-zero)
  exit 4  Validation             → threadId must be a positive number
  exit 3 (HTTP 403)  Permission denied      → requires a developer token; also refused under --read-only
  exit 5 (HTTP 404)  Not found              → check the threadId via \`ib message support inbox\`
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

SEE ALSO
  ib message support inbox, ib message chat list

EXAMPLES
  ib message support resolve 42
  ib message support resolve 42 --reopen
"
`;

exports[`Help snapshots — contract stability > help for ib notification fcm send matches snapshot 1`] = `
"USAGE
  ib notification fcm send [flags]

DESCRIPTION
  Send an FCM push notification to one person's registered devices. Admin/HR-gated server-side; the recipient is scoped to your company (a cross-tenant personId returns 404, not a push). --dry-run previews the recipient + active device count without sending.
  Permissions: requires company admin (isAsiakasAdmin) or HR admin (isHRAdmin) on the active company, or global sysadmin (server-enforced).

FLAGS
  --person STRING    Recipient personId, or a name resolved within your company (required)
  --title STRING    Notification title (required)
  --body STRING    Notification body (required)
  --data STRING    Extra FCM data payload as a JSON object (e.g. '{"url":"/grid"}')

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { success, reason:'SENT'|'NO_DEVICES'|'DELIVERY_FAILED', personId, name, devicesTargeted, messageUuid?, successCount?, failureCount?, hint? } | { dryRun:true, wouldSend:{ personId, name, title, body, deviceCount } } (with --dry-run)

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Invalid request: missing --title/--body, bad --person, ambiguous name, or non-object --data (NOT 'no devices' — that is a 200, see notes) → supply --title/--body and an unambiguous --person
  exit 3 (HTTP 403)  Not Admin/HR on the active company → switch to a company where you are admin/HR (ib company switch)
  exit 5 (HTTP 404)  Recipient not found in your company → check the personId / name belongs to your company
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Requires company admin (isAsiakasAdmin) or HR admin (isHRAdmin) on the active company, or a global sysadmin.
  - A non-numeric --person is resolved via the company-scoped person search: 0 matches → exit 5, >1 → exit 4 listing candidates (re-run with the personId).
  - The send OUTCOME is reported at HTTP 200 (exit 0) via \`reason\` — NOT as an error: SENT, NO_DEVICES (the person has no registered FCM device — a benign no-op), or DELIVERY_FAILED (all devices failed). Inspect \`success\`/\`reason\`/\`hint\`, not the exit code; a 4xx means the REQUEST was bad (validation/permission/recipient), not that delivery failed.

SEE ALSO
  ib person notify, ib person search

EXAMPLES
  ib notification fcm send --person 6233 --title 'Keikka siirretty' --body 'Huomisen keikka alkaa klo 8'
  ib notification fcm send --person 'Juha Urho' --title Muistutus --body 'Tarkista aikataulu' --dry-run
"
`;

exports[`Help snapshots — contract stability > help for ib ohje get matches snapshot 1`] = `
"USAGE
  ib ohje get <helpId> [flags]

DESCRIPTION
  Get one UI help-text entry by helpId — the title/shorttext/htmltext shown in a HelperIcon '(?)' modal in the web UI. This is end-user help CONTENT, distinct from \`ib --help\` (CLI usage). Returns null when the helpId has no entry yet. The HTTP route is unauthenticated, but ib calls it with your session token (login still required).
  Auth: requires login (any authenticated user).

ARGUMENTS
  <helpId> STRING    the helpId (e.g. LaskupohjaTilaus) (required)

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { helpId, title, shorttext, htmltext, img } | null

ERRORS (stderr, exit non-zero)
  exit 4  Invalid helpId         → helpId may contain only [A-Za-z0-9_-]
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib ohje get LaskupohjaTilaus
  ib ohje get LaskupohjaTilaus --pretty
"
`;

exports[`Help snapshots — contract stability > help for ib ohje list matches snapshot 1`] = `
"USAGE
  ib ohje list [flags]

DESCRIPTION
  List every UI help-text entry (the whole helps table). Useful to discover helpIds before \`ib ohje get\`/\`update\`. The HTTP route is unauthenticated, but ib calls it with your session token.
  Auth: requires login (any authenticated user).

FLAGS
  --limit NUMBER    Max rows to return (client-side cap)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  ListEnvelope<{ helpId, title, shorttext, htmltext, img }>

ERRORS (stderr, exit non-zero)
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib ohje list
  ib ohje list --limit 10 --pretty
"
`;

exports[`Help snapshots — contract stability > help for ib ohje update matches snapshot 1`] = `
"USAGE
  ib ohje update <helpId> [flags]

DESCRIPTION
  Update a UI help-text entry (PUT /api/helps/update). The CLI GET-merges the current row first, so fields you omit are PRESERVED (helps_save overwrites the whole row). Provide typed flags or --body JSON; typed flags win. --reason is required for a write. --dry-run previews the merged row CLIENT-SIDE without writing — the backend does not honour X-Dry-Run on this route. Mirrors the HelperIcon in-place editor.
  Permissions: requires isHelperEditor (or system-admin/developer).

ARGUMENTS
  <helpId> STRING    the helpId to update (created if it does not exist) (required)

FLAGS
  --body JSON    JSON with any of title/shorttext/htmltext/img (typed flags win)
  --title STRING    Help title (otsikko)
  --shorttext STRING    Short text
  --htmltext STRING    HTML body shown in the modal
  --img STRING    Image reference (pass "" to clear it to null)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { success: true, message } (raw backend response) or { dryRun: true, helpId, current, proposed }

ERRORS (stderr, exit non-zero)
  exit 4  Missing --reason / invalid helpId → pass --reason; helpId may contain only [A-Za-z0-9_-]
  exit 4 (HTTP 400)  Validation failed      → title ≤500, htmltext ≤10000, helpId [A-Za-z0-9_-]
  exit 3 (HTTP 403)  Permission denied      → needs isHelperEditor or system-admin/developer
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib ohje update LaskupohjaTilaus --title "Laskupohja" --htmltext "<p>Ohje…</p>" --reason "content fix"
  ib ohje update LaskupohjaTilaus --dry-run --title "New title"
  ib ohje update LaskupohjaTilaus --body '{"title":"X","htmltext":"<p>Y</p>"}' --reason edit
"
`;

exports[`Help snapshots — contract stability > help for ib perf clear matches snapshot 1`] = `
"USAGE
  ib perf clear [flags]

DESCRIPTION
  Clear the slow-query buffer for one environment. Previews with --dry-run (client-side); --reason recommended for the audit log. Developer-only; refused under --read-only.
  Permissions: requires isSystemAdmin or isDeveloper.

FLAGS
  --env STRING    Environment buffer to clear (default: backend's current env)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  execute: { cleared:true, environment, message } | --dry-run: { dryRun:true, wouldClear:{ method, path } }

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Not a developer        → requires isSystemAdmin or isDeveloper
  exit 6 (HTTP 500)  Backend error          → retry with --verbose
  exit 3  Blocked by read-only mode → clearing needs a session without --read-only/IB_READ_ONLY

NOTES
  - The DELETE route honours no server-side X-Dry-Run — --dry-run is resolved CLIENT-SIDE (never sends).

SEE ALSO
  ib perf stats

EXAMPLES
  ib perf clear --env staging --reason "reset after load test"
  ib perf clear --dry-run
"
`;

exports[`Help snapshots — contract stability > help for ib perf config matches snapshot 1`] = `
"USAGE
  ib perf config [flags]

DESCRIPTION
  Slow-query collector configuration (enabled, threshold, sentryThreshold, maxEntries, current environment) plus availableEnvironments that have data. Developer-only.
  Permissions: requires isSystemAdmin or isDeveloper.

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { enabled, threshold, sentryThreshold, maxEntries, environment, availableEnvironments:[string] }

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Not a developer        → requires isSystemAdmin or isDeveloper
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

SEE ALSO
  ib perf slow, ib perf stats

EXAMPLES
  ib perf config
"
`;

exports[`Help snapshots — contract stability > help for ib perf slow matches snapshot 1`] = `
"USAGE
  ib perf slow [flags]

DESCRIPTION
  Recent slow queries from the collector's Redis ring buffer (procedure, durationMs, entity, params, timestamp). Developer-only.
  Permissions: requires isSystemAdmin or isDeveloper.

FLAGS
  --limit NUMBER    Max rows (default: 50)
  --env STRING    Environment buffer to read (default: backend's current env; discover via \`ib perf config\`)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  ListEnvelope<{ procedure, durationMs, entity, params, timestamp }> & { totalCount?, environment? } (+truncated:true when the page filled the limit)

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Not a developer        → requires isSystemAdmin or isDeveloper
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - SQL durations cover the executeQuery (cache-runner) path only — raw getConnection() queries are not timed.
  - Threshold to be 'slow' is the collector's SLOW_QUERY_THRESHOLD_MS (default 1000ms) — see \`ib perf config\`.

SEE ALSO
  ib perf stats, ib perf config

EXAMPLES
  ib perf slow
  ib perf slow --limit 20 --env production
"
`;

