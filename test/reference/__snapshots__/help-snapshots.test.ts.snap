exports[`Help snapshots — contract stability > help for ib stats matches snapshot 1`] = `
"USAGE
  ib stats [flags]

DESCRIPTION
  Aggregated delivery statistics for a date range: m³ volume, order counts, and breakdowns by customer/vehicle/driver/worksite/status/day. Read-only; scoped to what the caller can see in the grid.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --from DATE    Start date (YYYY-MM-DD or today/yesterday/tomorrow)
  --to DATE    End date (YYYY-MM-DD or today/yesterday/tomorrow)
  --today BOOLEAN    Shortcut for --from today --to today
  --month STRING    Whole calendar month YYYY-MM (expands to first→last day)
  --week DATE    7-day window starting <start>
  --by STRING    Single breakdown: customer|vehicle|driver|worksite|status|day (omit for full bundle)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  No --by: { period, totals:{orders,m3,activeVehicles,activeDrivers}, byStatus, byCustomer, byVehicle, byDriver, byWorksite, byDay }. With --by: ListEnvelope of that one breakdown.

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Default range is today. Exactly one of --today/--month/--week/(--from & --to).
  - Deploy-gated: returns 404 until GET /api/cli/stats is deployed.
  - Revenue and driver hours are out of scope (v1).

EXAMPLES
  ib stats --month 2026-06
  ib stats --from 2026-06-01 --to 2026-06-07 --by driver
  ib stats --today --pretty
"
`;

exports[`Help snapshots — contract stability > help for ib validate matches snapshot 1`] = `
"USAGE
  ib validate [<action>] [flags]

DESCRIPTION
  Validate a company OR a single employee against a profile — a pass/fail/skip checklist with Finnish details naming what is missing. Entity is inferred from --person: absent → company (profiles: jerry, betoni; --profile required); present → person (profile: onboarding, default). \`ib validate list\` lists profiles. Company: GET /api/validation/:profile/:asiakasId. Person: GET /api/validation/person/:profile/:asiakasId/:personId.
  Permissions: requires company: system admin OR admin-tier role in the target (or owner) company, person: the above OR HR admin (typeId 24) of the target company.

ARGUMENTS
  <action> STRING    Use 'list' to list available profiles; omit to run validation. (optional)

FLAGS
  --asiakas NUMBER    Target asiakasId (default: active company)
  --person NUMBER    Validate this person as an employee (switches to person validation)
  --profile STRING    Profile id (company: jerry|betoni, required; person: onboarding, default)
  --keikka NUMBER    Validate this keikka against the reminders-drawer rules (alias of \`ib keikka validate <id>\`)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  list: ListEnvelope<{ id, titleFi, description, entity:'company'|'person' }>. company: { entity:'company', profile, asiakasId, asiakasNimi, ok, summary, checks[] }. person: { entity:'person', profile, asiakasId, asiakasNimi, personId, personNimi, ok, summary, checks:[{ id, severity, status:'pass'|'fail'|'skip', titleFi, detail? }] }.

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Not an admin/HR of the target company → use an admin/HR token
  exit 5 (HTTP 404)  Unknown profile for that entity, or company/person not found → run \`ib validate list\` to see profiles
  exit 4  Missing --profile for company validation, or a non-positive --asiakas/--person → pass --profile (jerry|betoni) for a company, or a positive --asiakas/--person; run \`ib validate list\`

NOTES
  - ok = every applicable 'required' check passes; skipped checks (conditional, not applicable) and recommended/optional never flip it.
  - status 'skip' = the check did not apply (e.g. Ajoneuvot-moduuli only checked for pumppari); excluded from summary counts.
  - Exit code is 0 even when ok:false — the JSON carries the outcome.
  - Deploy-gated: returns 404 until /api/validation is deployed.
  - 'ib company validate' was renamed to this command (exit 4 on the old path).

SEE ALSO
  ib person get, ib customer modules, ib jerry admin detail

EXAMPLES
  ib validate list
  ib validate --asiakas 8 --profile betoni
  ib validate --asiakas 8 --person 10
  ib validate --person 10 --profile onboarding
  ib validate --keikka 9001
"
`;

exports[`Help snapshots — contract stability > help for ib vehicle create matches snapshot 1`] = `
"USAGE
  ib vehicle create [flags]

DESCRIPTION
  Create a vehicle. Two-step backend flow (POST /api/vehicle/new then /save); ownerAsiakasId from JWT. Dry-run previews via /new without inserting.
  Permissions: requires auth.page.vehicle.edit.

FLAGS
  --reg STRING    Registration number (vehicleRegNo)
  --name STRING    Display name (vehicleNimi)
  --no NUMBER    Fleet number (vehicleNo)
  --type NUMBER    vehicleTypeId (see ib vehicle types)
  --memo STRING    Free-text memo
  --default-driver NUMBER    Default driver personId
  --capacity NUMBER    Concrete capacity in m3 (vehicleM3)
  --asiakas NUMBER    Owning asiakasId (defaults to active company)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { vehicleId, ... } (raw backend save response) | { dryRun, wouldCreate }

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Validation failed      → fix the field flags
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.vehicle.edit
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib vehicle create --reg ABC-123 --type 1 --capacity 7.5 --reason 'new truck'
  ib vehicle create --reg ABC-123 --dry-run
"
`;

