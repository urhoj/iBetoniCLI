exports[`Help snapshots — contract stability > help for ib dev schema dump matches snapshot 1`] = `
"USAGE
  ib dev schema dump [flags]

DESCRIPTION
  Whole-schema structural map of the dbo schema (developer-gated, read-only) — all tables with column names and types, FK edges, view names, and proc signatures. No proc/view bodies (use \`schema proc\`/\`schema view\` for those).
  Permissions: requires developer access (isSystemAdmin or isDeveloper).

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { tables:[{name,columns}], foreignKeys:[{table,column,refTable,refColumn}], views:[{name}], procs:[{name,type,parameters}] }

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Not a developer        → run \`ib auth whoami\`; if not a developer, \`ib auth login\` as a developer account (same person re-login won't grant it). Gate is server-side — a new DB flag only applies once --endpoint's backend is redeployed.
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib dev schema dump
"
`;

