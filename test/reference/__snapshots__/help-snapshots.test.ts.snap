exports[`Help snapshots — contract stability > help for ib person role revoke matches snapshot 1`] = `
"USAGE
  ib person role revoke <personId> [flags]

DESCRIPTION
  Revoke a per-company role from a person (idempotent: { removed:0 } when absent). Looks up the asiakasPersonSettingId then DELETEs it. --dry-run previews via the backend ({ dryRun:true, wouldDelete }).
  Permissions: requires company admin on the target tenant (tier per role).

ARGUMENTS
  <personId> NUMBER    personId (required)

FLAGS
  --role STRING    Role name (REQUIRED)
  --asiakas NUMBER    Target asiakasId (REQUIRED)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { removed: 1 } | { removed: 0 } (absent) | { dryRun:true, wouldDelete:{ asiakasPersonSettingId }, validation }

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Unknown role           → use a name from ROLE_TYPEID_BY_NAME
  exit 3 (HTTP 403)  Not a tenant admin     → use a system-admin token or a tenant admin
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib person role revoke 5351 --role keikkaHandler --asiakas 26 --reason rotation
"
`;

exports[`Help snapshots — contract stability > help for ib person search matches snapshot 1`] = `
"USAGE
  ib person search <query> [flags]

DESCRIPTION
  Free-text search across person names / emails. POST /api/person/search. Scoped to your active company. With --my-companies the search runs across every company you belong to in one server-side call (with a per-company client-sweep fallback if that endpoint isn't deployed yet) and returns one flat list tagged with the asiakasId/name of each hit. Global persons (ownerAsiakasId=null) are included in every company's results.
  Permissions: requires auth.page.person.read.

ARGUMENTS
  <query> STRING    search string (required)

FLAGS
  --limit NUMBER    Max results (default: 50)
  --my-companies BOOLEAN    Search across all companies you belong to; each hit carries its asiakasId/asiakasName

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  ListEnvelope<{ personId, name, email, phone, asiakasId }>. With --my-companies each row also carries asiakasName, and the envelope gains truncated:true when the result hit the limit (backend ≥ 2026-06-11).

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.person.read
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib person search 'Matti'
  ib person search 'Ikonen' --my-companies
"
`;

