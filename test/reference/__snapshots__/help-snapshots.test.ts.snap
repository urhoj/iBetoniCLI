"
`;

exports[`Help snapshots — contract stability > help for ib message daily get matches snapshot 1`] = `
"USAGE
  ib message daily get <boxId> [flags]

DESCRIPTION
  One daily box's row + its message for the date + its permission rows, resolved client-side over the list (there is no per-box GET).
  Auth: requires login (any authenticated user).
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

ARGUMENTS
  <boxId> NUMBER    Box to fetch (required)

FLAGS
  --asiakas NUMBER    Company the box is listed for (asiakasId) (required)
  --date DATE    Date for the message (YYYYMMDD | YYYY-MM-DD | today)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { box: { boxId, boxTitle, boxLisatieto?, ownerAsiakasId, dailyMessageBoxAsiakasId }, message: {...}|null, permissions: {...}[] }

ERRORS (stderr, exit non-zero)
  exit 5 (HTTP 404)  Box not visible for the company → ib message daily list <asiakasId>
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 4 (HTTP 400)  Validation error (bad date/ids/missing fields) → check the flags
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib message daily get 36 --asiakas 8 --date today
"
`;

exports[`Help snapshots — contract stability > help for ib message daily grant matches snapshot 1`] = `
"USAGE
  ib message daily grant <boxId> [flags]

DESCRIPTION
  Add a per-role ACL row on a shared box. The row defaults read-only — adjust read/edit afterwards with \`perm-set\`.
  Auth: requires login (any authenticated user).

ARGUMENTS
  <boxId> NUMBER    Box the rule applies to (required)

FLAGS
  --to NUMBER    Tenant (asiakasId) the role belongs to (required)
  --role NUMBER    asiakasPersonSettingTypeId (e.g. 8=Pumppari, 2=Admin) (required)
  --box-asiakas NUMBER    dailyMessageBoxAsiakasId of the share row (required)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { success, dailyMessageBoxAsiakasPermissionsId? }

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 4 (HTTP 400)  Validation error (bad date/ids/missing fields) → check the flags
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

SEE ALSO
  ib message daily perm-set, ib message daily revoke

EXAMPLES
  ib message daily grant 36 --to 8 --role 8 --box-asiakas 34
"
`;

exports[`Help snapshots — contract stability > help for ib message daily list matches snapshot 1`] = `
"USAGE
  ib message daily list [<asiakasId>] [flags]

DESCRIPTION
  List a company's daily-message boxes; with --date, also that date's message text and the per-role permission rows. Returns the composite { boxes, messages, boxPermissions } (not a flat list).
  Auth: requires login (any authenticated user).
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

ARGUMENTS
  <asiakasId> NUMBER    Company to list boxes for (or --asiakas) (optional)

FLAGS
  --asiakas NUMBER    Target asiakasId (alias for the positional)
  --date DATE    Date for messages: YYYYMMDD | YYYY-MM-DD | today/yesterday/tomorrow

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { boxes: { boxId, boxTitle, boxLisatieto?, ownerAsiakasId, dailyMessageBoxAsiakasId }[], messages: {...}[], boxPermissions: {...}[] }

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 4 (HTTP 400)  Validation error (bad date/ids/missing fields) → check the flags
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
