exports[`Help snapshots — contract stability > help for ib customer create matches snapshot 1`] = `
"USAGE
  ib customer create [flags]

DESCRIPTION
  Create a new customer via POST /api/asiakas/createY. Body forwarded verbatim.
  Permissions: requires auth.page.asiakas.edit.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --body JSON    JSON object with the new customer fields

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json

OUTPUT (JSON, stdout)
  { asiakasId, ... } (raw backend response)

ERRORS (stderr, exit non-zero)
  400  Validation failed      → fix --body fields
  401  Token expired          → ib auth refresh
  403  Permission denied      → check auth.page.asiakas.edit
  500  Backend error          → retry with --verbose

EXAMPLES
  ib customer create --body '{"name":"Example Oy","yTunnus":"1234567-8"}' --idempotency-key new-example-oy
"
`;

exports[`Help snapshots — contract stability > help for ib customer delete matches snapshot 1`] = `
"USAGE
  ib customer delete [flags]

DESCRIPTION
  Delete a customer (asiakas). Requires --reason; --dry-run available.
  Permissions: requires auth.page.asiakas.edit.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
