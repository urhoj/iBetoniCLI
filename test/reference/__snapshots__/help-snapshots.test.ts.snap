exports[`Help snapshots — contract stability > help for ib person owner matches snapshot 1`] = `
"USAGE
  ib person owner <personId> [flags]

DESCRIPTION
  Set or clear a person's owner company (ownerAsiakasId). Provide EXACTLY ONE of --global (make the person GLOBAL/self-managing, ownerAsiakasId=null, discoverable across companies) or --asiakas <id> (assign/move ownership). This is SEPARATE from roles — a global person can still hold roles via \`ib person role grant\`, and from membership via \`ib customer person add\`. Requires --reason.
  Permissions: requires developer/system-admin: any person → any target, self (your own personId): → null always; → a company only if you are a member of it, company-admin: may release a person CURRENTLY owned by your company → global (cannot pull others in).

ARGUMENTS
  <personId> NUMBER    personId whose owner to change (required)

FLAGS
  --global BOOLEAN    Make the person global (ownerAsiakasId=null)
  --asiakas NUMBER    Set owner to this asiakasId
  --reason STRING    Audit-log reason (REQUIRED)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  { personId, ownerAsiakasId } or { dryRun: true, wouldSetOwner: { personId, from, to } }

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Not allowed to change this person's owner → see the authz rules above (developer/self/company-admin)
  exit 5 (HTTP 404)  Person not found       → verify personId
  exit 4  Bad flags              → provide exactly one of --global / --asiakas and a --reason

EXAMPLES
  ib person owner 5351 --global --reason 'make self-managing'
  ib person owner 5351 --asiakas 26 --reason 'assign to company 26'
  ib person owner 5351 --global --reason preview --dry-run
"
`;

exports[`Help snapshots — contract stability > help for ib person role grant matches snapshot 1`] = `
"USAGE
  ib person role grant <personId> [flags]

DESCRIPTION
  Grant a per-company role to a person. POST /api/asiakasPersonSettings/add/:asiakasId/:personId/:roleTypeId. Admin-gated on the tenant (tier depends on the role). --dry-run previews via the backend ({ dryRun:true, wouldCreate }).
  Permissions: requires company admin on the target tenant (tier per role).

ARGUMENTS
  <personId> NUMBER    personId (required)

FLAGS
  --role STRING    Role name (REQUIRED), e.g. keikkaHandler, vehicleHandler, hrAdmin
  --asiakas NUMBER    Target asiakasId (REQUIRED)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  raw backend success | { dryRun:true, wouldCreate:{ personId, asiakasId, personSettingTypeId, personSettingString }, validation }

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Unknown role / company limit reached → use a name from ROLE_TYPEID_BY_NAME
  exit 3 (HTTP 403)  Not a tenant admin     → use a system-admin token or a tenant admin
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib person role grant 5351 --role keikkaHandler --asiakas 26 --reason 'onboard handler'
  ib person role grant 5351 --role vehicleHandler --asiakas 26 --reason preview --dry-run
"
`;

