exports[`Help snapshots — contract stability > help for ib jerry check-address matches snapshot 1`] = `
"USAGE
  ib jerry check-address [flags]

DESCRIPTION
  Geofence feasibility probe (POST /api/pumppuRequests/checkAddress; the route is unauthenticated, but ib calls it with your session): which provider varikot cover an address. The single best tool for diagnosing 'no offers'. --address is required (the \`osoite\` body field); if --lat/--lng/--place-id are all supplied the server trusts them instead of re-geocoding. Not a mutation, so no write-safety flags. Rate-limited 10/min per IP. The \`providers\` array is only included when the token is a developer/admin.
  Auth: requires login (any authenticated user).

FLAGS
  --address STRING    Street address to check (REQUIRED; sent as \`osoite\`)
  --lat NUMBER    Latitude (trusted only with --lng + --place-id)
  --lng NUMBER    Longitude (trusted only with --lat + --place-id)
  --place-id STRING    Google placeId (lets the server trust client coords)
  --formatted-address STRING    Google formatted address

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { geocoded: boolean, deliverable?: boolean, lat?, lng?, placeId?, formattedAddress?, providerCount?, nearestVarikkoKm?, providers?: [{ asiakasId, asiakasNimi, distanceKm }] }

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  osoite missing         → pass --address
  exit 4 (HTTP 429)  Rate limit (10/min/IP) → wait and retry
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - A varikko counts toward providerCount only when ALL THREE hold: the company has isPumppuToimittaja = 1, the company has the HAS_JERRY setting on (ib jerry admin enable), and the sijainti is enrolled (jerryActiveUntil in the future, ib sijainti set-jerry --on) with maxDeliveryDistance covering the point.

EXAMPLES
  ib jerry check-address --address 'Mannerheimintie 1, Helsinki'
  ib jerry check-address --address 'Hämeenkatu 1, Tampere' --lat 61.498 --lng 23.761 --place-id ChIJxxxx
"
`;

