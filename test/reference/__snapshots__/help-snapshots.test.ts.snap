exports[`Help snapshots — contract stability > help for ib changelog add matches snapshot 1`] = `
"USAGE
  ib changelog add [flags]

DESCRIPTION
  Add a change entry (feature|improvement|bugfix). The monthly report is generated from these. --feedback <id> auto-resolves that cliFeedback row.
  Auth: requires login (any authenticated user).
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --type STRING    feature|improvement|bugfix (required)
  --area STRING    frontend|backend|cli|database|cicd (required)
  --title STRING    Entry title (required)
  --description STRING    Kuvaus (required)
  --benefits STRING    Hyödyt
  --impact STRING    Vaikutus
  --status STRING    Tila (Julkaistu/Korjattu/...)
  --severity STRING    Bug severity (Kriittinen/Korkea/Normaali/Matala)
  --files STRING    CSV of file paths
  --repo STRING    Repo/submodule
  --sha STRING    Commit SHAs (CSV)
  --vtag STRING    Version tag
  --bump-level STRING    App version bump this implies: none|patch|minor|major (default: patch)
  --feedback NUMBER    cliFeedback id this entry resolves
  --sentry STRING    Sentry issue short id or URL this entry fixes (stored, not sent to Sentry)
  --date DATE    Entry date (YYYY-MM-DD|today)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { changelogId } | { dryRun, wouldCreate, validation }

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Developer access required → use a developer token
  exit 4 (HTTP 400)  Validation (bad enum/date) → check --type/--area/--date
  exit 2 (HTTP 401)  Token expired          → ib auth refresh

NOTES
  - --dry-run is SERVER-side (X-Dry-Run): the backend validates the payload then echoes wouldCreate without inserting — a bad --type/--area/--date still 400s under --dry-run.
  - Developer-gated.

SEE ALSO
  ib changelog report, ib feedback resolve

EXAMPLES
  ib changelog add --type bugfix --area cli --title "x" --description "y" --feedback 12 --sha 59d9cc5
  ib changelog add --type bugfix --area backend --title "fix npe" --description "y" --sentry PUMINET5API-1A2
"
`;

exports[`Help snapshots — contract stability > help for ib changelog get matches snapshot 1`] = `
"USAGE
  ib changelog get <changelogId> [flags]

DESCRIPTION
  Get one change entry.
  Auth: requires login (any authenticated user).

ARGUMENTS
  <changelogId> NUMBER    Entry id (required)

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

