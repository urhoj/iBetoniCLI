exports[`Help snapshots — contract stability > help for ib reference detail delete matches snapshot 1`] = `
"USAGE
  ib reference detail delete <command...> [flags]

DESCRIPTION
  Delete one command-catalog row by its exact key — prunes orphans of re-homed/removed commands (developer only)
  Auth: requires login (any authenticated user).

ARGUMENTS
  <command...> STRING    The exact stored command key after \`ib\` (e.g. ai conversation). Unlike get/set this is NOT validated against the live catalogue — that is precisely what lets you remove an orphan whose command no longer exists. (required)

FLAGS
  (none)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { deleted } (rows removed, 0 or 1 — idempotent) | --dry-run: { dryRun:true, wouldDelete:{ command, exists }, validation }

ERRORS (stderr, exit non-zero)
  exit 3  Not a developer        → Requires isDeveloper / isSystemAdmin
  exit 4  Missing --reason on a real delete, or empty command path → Pass --reason (or --dry-run to preview) and a command path

EXAMPLES
  ib reference detail delete ai conversation --dry-run
  ib reference detail delete ai conversation --reason 'orphan: ai domain re-homed under dev'
"
`;

exports[`Help snapshots — contract stability > help for ib reference detail get matches snapshot 1`] = `
"USAGE
  ib reference detail get <command...> [flags]

DESCRIPTION
  On-demand business/AI context for one command (DB-backed via /api/cli/command-catalog); exit 5 if none
  Auth: requires login (any authenticated user).

ARGUMENTS
  <command...> STRING    Command path after \`ib\` (e.g. keikka latest) (required)

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { command, summary, detail, hint }. exit 5 when unknown or no detail yet.

ERRORS (stderr, exit non-zero)
  exit 5  Unknown command or no detail yet → \`ib commands\` / \`ib reference dump\` for valid paths; or \`<cmd> --help\`

EXAMPLES
  ib reference detail get keikka latest
  ib reference detail get jerry check-address
"
`;

exports[`Help snapshots — contract stability > help for ib reference detail lint matches snapshot 1`] = `
"USAGE
  ib reference detail lint [flags]

DESCRIPTION
  Audit the command-catalog for orphan rows — keys with no live command (re-homed/renamed leftovers); --strict for CI (developer only)
  Auth: requires login (any authenticated user).

FLAGS
  --strict BOOLEAN    Exit 1 if any orphan row exists (for CI)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { items: [{ command, severity:'warn', kind:'orphan', summary, hint }], count } — one finding per catalog key with no live command

ERRORS (stderr, exit non-zero)
  exit 1  --strict and orphan rows found → Prune each with \`ib reference detail delete <key> --reason <r>\`, or seed the re-homed command
  exit 3  Not a developer        → Requires isDeveloper / isSystemAdmin

NOTES
  - Read-only: one GET of the whole catalog plus a local diff against the live command specs. The class behind fb#73 (\`ib customer prh\` re-homed to \`ib opendata prh\`).

SEE ALSO
  ib reference detail delete, ib reference detail list

EXAMPLES
  ib reference detail lint
  ib reference detail lint --strict
"
`;

exports[`Help snapshots — contract stability > help for ib reference detail list matches snapshot 1`] = `
"USAGE
  ib reference detail list [flags]

DESCRIPTION
  List command-catalog entries, optionally ordered by stalest (DB-backed)
  Auth: requires login (any authenticated user).

FLAGS
  --stalest NUMBER    Return up to N entries sorted by least-recently reviewed
  --domain STRING    Only commands in this ib domain (e.g. attachment) — narrows BEFORE --stalest, so the budget isn't spent on unrelated commands
  --with-detail BOOLEAN    Include each entry's full detail text (adds a \`detail\` field per item), folding the per-command \`reference detail get\` into this one call. Needs the backend deployed; on an old backend the field is simply absent.
  --needs-review BOOLEAN    Only rows still needing grooming: aiConfidence below the threshold (or unassessed) AND not parked, oldest-first.
  --max-confidence NUMBER    Threshold for --needs-review (default 90).

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { items: [{ command, summary, lastReviewed, runs, aiConfidence, needsHumanReview, detail? }], count } — \`detail\` present only with --with-detail

ERRORS (stderr, exit non-zero)
  exit 2  Not authenticated      → Run \`ib auth login\`
  exit 4  Unknown --domain       → \`ib commands\` for valid domains

EXAMPLES
  ib reference detail list
  ib reference detail list --stalest 20
  ib reference detail list --stalest 10 --domain attachment
  ib reference detail list --stalest 10 --domain attachment --with-detail
  ib reference detail list --needs-review --max-confidence 90
"
`;

exports[`Help snapshots — contract stability > help for ib reference detail set matches snapshot 1`] = `
"USAGE
  ib reference detail set <command...> [flags]

DESCRIPTION
  Write summary and/or detail for one command in the command-catalog (developer only)
  Auth: requires login (any authenticated user).

ARGUMENTS
  <command...> STRING    Command path after \`ib\` (e.g. keikka latest) (required)

FLAGS
  --summary STRING    Short one-line summary stored in the catalog
  --detail STRING    Full markdown business-context detail
  --ai-confidence NUMBER    Self-assessed completeness/correctness 0–100 (groom rubric). Omit on a human edit to reset the score.
  --needs-human-review BOOLEAN    Park the row for a human (excludes it from --needs-review); set with a low --ai-confidence when blocked.
  --field STRING    Edit-mode target field: summary | detail (default detail)
  --replace STRING    Edit mode: replace this literal text in the target field (exactly once unless --all)
  --with STRING    Replacement for --replace ("" deletes the matched text)
  --append STRING    Edit mode: append text to the target field (verbatim)
  --prepend STRING    Edit mode: prepend text to the target field (verbatim)
  --all BOOLEAN    With --replace: substitute every occurrence

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { command, runs, … } (backend response) | edit dry-run: {dryRun:true, command, field, matchCount?, addedLines, removedLines, sameContent, unified}

ERRORS (stderr, exit non-zero)
  exit 5  Unknown command        → \`ib commands\` for valid paths

EXAMPLES
  ib reference detail set keikka list --summary 'Lists delivery orders' --reason 'initial fill'
  ib reference detail set keikka list --detail '## Keikka list\\nReturns ...' --reason 'update'
  ib reference detail set keikka list --replace '14 latest' --with '20 latest' --reason 'fix count' --dry-run
"
`;

exports[`Help snapshots — contract stability > help for ib reference dump matches snapshot 1`] = `
"USAGE
  ib reference dump [<domain...>] [flags]

DESCRIPTION
  Emit the full command surface as JSON for one-shot AI ingestion. The universal 401/500 error contract is hoisted to a single top-level \`commonErrors\` block and stripped from each spec (it applied to every command) — read \`commonErrors\` together with each spec's command-specific \`errors\`. Pass one or more domains (the token after \`ib\`, e.g. keikka) to narrow the commands map — STRONGLY preferred over the full surface (a one-domain dump is a fraction of the bytes). The full (no-domain) dump carries a \`notice\` field pointing this out. \`glossary\` (the term+synonyms vocabulary index) is OPT-IN via \`--glossary\`. \`--commands-only\` emits just { version, generatedAt, commonErrors, commands } for callers that already know the domain.
  Auth: none (public).

ARGUMENTS
  <domain...> STRING    Restrict the commands map to one or more domains (the token after \`ib\`, e.g. keikka). Multiple domains share a single primer. Unknown domain exits 4 listing valid domains. (optional)

FLAGS
  --glossary BOOLEAN    Include the term+synonyms vocabulary INDEX (fetched from the DB) under \`glossary\`. Off by default to keep the dump small; fetch definitions on demand with \`ib glossary lookup <term>\` / \`ib glossary list\`.
  --commands-only BOOLEAN    Emit only { version, generatedAt, commonErrors, commands } — drop the overview/topics/feedbackGuidance primer and skip the glossary fetch (no token needed). Fewer bytes per dump.
  --lean BOOLEAN    Drop each command's \`notes\`/\`seeAlso\` prose (KEEPS \`examples\`) — ~7.6k fewer tokens on the full surface. For a whole-surface scan you get what exists + how to call it; fetch the dropped caveats/cross-refs per-command via \`ib <command> --help\`. Composes with --commands-only and domain filters.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { version, generatedAt, commonErrors: CommandError[], notice?, overview, glossary, feedbackGuidance, topics, commands: { '<command>': CommandSpec } } — with --commands-only: { version, generatedAt, commonErrors, commands }; with --lean each spec drops notes/seeAlso (examples kept). \`commonErrors\` (401/500) applies to EVERY command and is omitted from each spec's \`errors\`. \`notice\` appears only on the full (no-domain) dump. \`glossary\` is the term+synonyms INDEX only and is EMPTY unless \`--glossary\` is passed; fetch a definition with \`ib glossary lookup <term>\` or all of them with \`ib glossary list\`.

ERRORS (stderr, exit non-zero)
  exit 4  Unknown domain         → run \`ib commands\` (no arg) to see valid domains
  exit 1  I/O error              → retry; check stdout pipe

EXAMPLES
  ib reference dump keikka
  ib reference dump --lean --commands-only
  ib reference dump --glossary
  ib reference dump | jq .commonErrors
"
`;

