FLAGS
  --top NUMBER    Return up to N

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { items:[{term,count,firstSeen,lastSeen,status}], count, truncated? }

ERRORS (stderr, exit non-zero)
