exports[`Help snapshots — contract stability > help for ib customer create matches snapshot 1`] = `
"USAGE
  ib customer create [flags]

DESCRIPTION
  Create a customer. Typed flags assemble the createY body (yTunnus REQUIRED); --from-prh prefills name+yTunnus+billing address from the PRH registry; --address/--postal-code/--city set the billing postal address; --body raw JSON overrides flags. Returns the flat customer shape via re-fetch.
  Permissions: requires auth.page.asiakas.edit.

FLAGS
  --name STRING    Customer name (asiakasNimi)
  --ytunnus STRING    Business ID (yTunnus) — required unless --from-prh/--body supplies it
  --email STRING    Invoicing email (laskutusEmail)
  --short-name STRING    Short display name (asiakasShortNimi)
  --from-prh STRING    Prefill name + yTunnus + billing address from PRH for this business ID
  --address STRING    Billing street address (laskutusOsoite)
  --postal-code STRING    Billing postal code (laskutusPostinumero)
  --city STRING    Billing city (laskutusKaupunki)
  --get-or-create BOOLEAN    If a customer with this yTunnus already exists, return it (reused:true) instead of creating a duplicate
  --body JSON    Raw JSON body (overrides typed flags)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  flat customer { asiakasId, name, yTunnus, type, address, postalCode, city, email, contactPersonId, shortName, comment } (or wouldCreate on --dry-run; with --get-or-create adds reused:boolean)

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Missing yTunnus / validation, or >1 customer shares the yTunnus with --get-or-create → pass --ytunnus or --from-prh; for an ambiguous match use \`ib customer get <id>\`
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.asiakas.edit
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib customer create --from-prh 0145937-9 --email billing@x.fi --reason onboard
  ib customer create --name 'Example Oy' --ytunnus 1234567-8
  ib customer create --from-prh 0145937-9 --get-or-create --reason onboard
"
`;

exports[`Help snapshots — contract stability > help for ib customer create-or-update matches snapshot 1`] = `
"USAGE
  ib customer create-or-update [flags]

DESCRIPTION
  Upsert a customer keyed by business ID (ytunnus) — removes the search-then-create dance for idempotent onboarding. Looks the ytunnus up in your tenant (system admins: across tenants); 1 match → update (read-merge with your flags), 0 → create, >1 → error (exit 4). --from-prh <yt> uses that business ID as the key AND prefills name+yTunnus from PRH on create. Alias: \`ib customer upsert\`.
  Permissions: requires auth.page.asiakas.edit.

FLAGS
  --ytunnus STRING    Business ID key (yTunnus) — required unless --from-prh/--body supplies it
  --from-prh STRING    Use this business ID as the key AND prefill name+yTunnus+billing address from PRH on create
  --name STRING    Customer name (asiakasNimi)
  --email STRING    Invoicing email (laskutusEmail)
  --short-name STRING    Short display name (asiakasShortNimi)
  --comment STRING    Comment (kommentti) — applied on update
  --contact-person NUMBER    Contact person id — applied on update
  --type NUMBER    Customer type id — applied on update
  --address STRING    Billing street address (laskutusOsoite)
  --postal-code STRING    Billing postal code (laskutusPostinumero)
  --city STRING    Billing city (laskutusKaupunki)
  --body JSON    Raw JSON body (overrides typed flags)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { ...flat customer, action: 'created'|'updated' } (action 'updated' also carries changed:boolean|null) · { action: 'would-*', dryRun } on --dry-run

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  No ytunnus key, or >1 customers share the ytunnus (ambiguous) → provide --ytunnus/--from-prh; for an ambiguous match use \`ib customer update <id>\`
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.asiakas.edit
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib customer create-or-update --from-prh 1234567-8 --reason 'PRH onboarding'
  ib customer upsert --ytunnus 1234567-8 --name 'Example Oy' --email billing@example.fi --reason onboard
"
`;

