exports[`Help snapshots — contract stability > help for ib keikka update matches snapshot 1`] = `
"USAGE
  ib keikka update <keikkaId> [flags]

DESCRIPTION
  Update a keikka. v1.0 supports only \`--status\` (the numeric keikkaTilaId, posted to POST /api/keikka/tila/set). Other field-setters land in v1.1.
  Permissions: requires auth.page.grid.tilaus.edit.

ARGUMENTS
  <keikkaId> NUMBER    keikkaId to update (required)

FLAGS
  --status STRING    New keikkaTilaId (numeric, e.g. 9 = Toimitettu)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { ok: true } or backend response

ERRORS (stderr, exit non-zero)
  exit 4  --status not a numeric keikkaTilaId → pass a number, e.g. --status 9
  exit 5 (HTTP 404)  Keikka not found       → verify keikkaId
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.grid.tilaus.edit
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - --status takes the numeric keikkaTilaId, NOT a name — e.g. \`--status 9\` (Toimitettu), \`--status 8\` (Peruttu), \`--status 2\` (Lähetetty). See the legend on \`ib keikka list --help\` or the \`tila\` GLOSSARY entry on \`ib --help\`.

EXAMPLES
  ib keikka update 9001 --status 9
  ib keikka update 9001 --status 8 --reason 'phone cancellation'
"
`;

exports[`Help snapshots — contract stability > help for ib keikka validate matches snapshot 1`] = `
"USAGE
  ib keikka validate [<keikkaId>] [flags]

DESCRIPTION
  Validate a keikka (or a whole day with --date) against the reminders-drawer rules
  Permissions: requires auth.page.grid.tilaus.read.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

ARGUMENTS
  <keikkaId> NUMBER    keikkaId to validate (omit when using --date) (optional)

FLAGS
  --date DATE    Validate every keikka for this date (YYYY-MM-DD or today/yesterday/tomorrow)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  single: { keikkaId, isValid, validationEnabled, summary:{totalIssues,critical,high,medium,low,notification,categories}, issues:[{type,message,priority,priorityName,category,categoryName,field}] } | day: { items:[{ keikkaId, isValid, summary, issues }], count, dayTotals:{totalIssues,critical,invalidKeikkas}, validationEnabled }

ERRORS (stderr, exit non-zero)
  exit 5 (HTTP 404)  Keikka not found       → verify keikkaId
  exit 4 (HTTP 400)  Bad date / keikkaId    → use YYYY-MM-DD or a positive integer
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.grid.tilaus.read
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - validationEnabled is the per-company grid master toggle; rules run regardless. Single 404 if the keikka is not visible; day mode validates every keikka for the date.

SEE ALSO
  ib validate, ib keikka get

EXAMPLES
  ib keikka validate 9001
  ib keikka validate --date today
"
`;

exports[`Help snapshots — contract stability > help for ib legal accept matches snapshot 1`] = `
"USAGE
  ib legal accept [<typeName>] [flags]

DESCRIPTION
  Record YOUR OWN acceptance of the current active version of a type. DEVELOPER TESTING AID, gated client-side to developer/sysadmin tokens — real consent is a human action recorded via the betoni.online / betonijerry.fi UI flows. The backend endpoint is self-only: you can never accept on someone else's behalf. --reason required unless --dry-run.
  Permissions: requires isSystemAdmin or isDeveloper (client-side gate).

ARGUMENTS
  <typeName> STRING    Document type name (see ib legal types; or pass --type) (optional)

FLAGS
  --type STRING    Document type name (alias for the positional)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  {success} | dry-run: {dryRun: true, wouldAccept: {...}, validation}

ERRORS (stderr, exit non-zero)
  exit 3  Not a developer/sysadmin token (client-side gate) → use a developer account
  exit 4  Missing typeName / missing --reason / type has no personSettingTypeId mapping → pass <typeName> and --reason; check ib legal types
  exit 5 (HTTP 404)  No active document of this type → ib legal versions <typeName>
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Resolves the active version via two sequential reads (current + types); if another developer activates a new version between them, the recorded version string can be one step stale. Acceptable for a testing aid — verify with ib legal status afterwards.

SEE ALSO
  ib legal status, ib legal show

EXAMPLES
  ib legal accept BETONIJERRY_TOS --reason "acceptance flow e2e test"
  ib legal accept TOS --dry-run
"
`;

exports[`Help snapshots — contract stability > help for ib legal acceptances matches snapshot 1`] = `
"USAGE
  ib legal acceptances <typeName> [flags]

DESCRIPTION
  Compliance report (developer/sysadmin only): WHO has accepted a document type — personId, name, email, accepted version + timestamp, newest first. Capped at 500 rows with a truncated flag. Types with NULL personSettingTypeId (e.g. GLOBAL today) are not trackable and return a validation error.
  Permissions: requires isSystemAdmin or isDeveloper (server-enforced).

ARGUMENTS
  <typeName> STRING    Document type name (see ib legal types) (required)

FLAGS
  --doc-version STRING    Only acceptances of this version string (NOT --version — that is the global CLI version flag)
  --limit NUMBER    Max rows (cap 500) (default: 500)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  ListEnvelope<{personId, firstName, lastName, email, acceptedVersion, acceptedAt}> & {typeName, personSettingTypeId, truncated?}

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Type has no personSettingTypeId mapping → fix the legalDocumentTypes row first
  exit 5 (HTTP 404)  Unknown document type  → ib legal types
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Developer/sysadmin only (server-enforced) → use a developer account token
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

SEE ALSO
  ib legal status, ib legal types

EXAMPLES
  ib legal acceptances BETONIJERRY_TOS
  ib legal acceptances TOS --doc-version 2.0
"
`;

exports[`Help snapshots — contract stability > help for ib legal activate matches snapshot 1`] = `
"USAGE
  ib legal activate <documentId> [flags]

DESCRIPTION
  Publish a document version (developer/sysadmin only): atomically archives the current active version of the same type+tenant (status='archived') and activates this one (status='active', isActive=1; also stamps effectiveDate). Use to publish a draft or roll back to an earlier version.
  Permissions: requires isSystemAdmin or isDeveloper (server-enforced).

ARGUMENTS
  <documentId> NUMBER    legalDocuments.documentId to activate (required)

FLAGS
  (none)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  {success} | dry-run: {dryRun: true, wouldActivate: {documentId}, validation}

ERRORS (stderr, exit non-zero)
  exit 4  Missing --reason or invalid documentId → pass --reason 'why' (not needed with --dry-run)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Developer/sysadmin only (server-enforced) → use a developer account token
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

SEE ALSO
  ib legal save, ib legal versions

EXAMPLES
  ib legal activate 12 --reason "publish v2.1"
"
`;

exports[`Help snapshots — contract stability > help for ib legal active matches snapshot 1`] = `
"USAGE
  ib legal active [flags]

DESCRIPTION
  Roll-up of the current ACTIVE document of EVERY type in one call — the single-view answer to 'what legal text is live right now'. One row per type: types with no active version appear with hasActive:false (not dropped). Content is stripped (contentLength only) — read a body via ib legal show <typeName>. Client-side fan-out over ib legal types + ib legal show.
  Auth: requires login (any authenticated user).

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  ListEnvelope<{typeName, displayName, personSettingTypeId, hasActive, documentId, version, title, effectiveDate, contentLength}>

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Also reachable as \`ib legal list\` (alias) — \`active\` is the legal group's analog of other domains' \`list\`.

SEE ALSO
  ib legal types, ib legal show

EXAMPLES
  ib legal active
  ib legal list
"
`;

exports[`Help snapshots — contract stability > help for ib legal delete matches snapshot 1`] = `
"USAGE
  ib legal delete <documentId> [flags]

DESCRIPTION
  Soft-delete a document version (developer/sysadmin only): sets status='deleted' (isActive=0) so it is distinguishable from a draft or superseded version in ib legal versions. The row and all acceptance history remain in the database.
  Permissions: requires isSystemAdmin or isDeveloper (server-enforced).

ARGUMENTS
  <documentId> NUMBER    legalDocuments.documentId to soft-delete (required)

FLAGS
  (none)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  {success} | dry-run: {dryRun: true, wouldDelete: {documentId}, validation}

ERRORS (stderr, exit non-zero)
  exit 4  Missing --reason or invalid documentId → pass --reason 'why' (not needed with --dry-run)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Developer/sysadmin only (server-enforced) → use a developer account token
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

SEE ALSO
  ib legal versions

EXAMPLES
  ib legal delete 12 --reason "superseded stub" --dry-run
"
`;

exports[`Help snapshots — contract stability > help for ib legal diff matches snapshot 1`] = `
"USAGE
  ib legal diff [<a>] [<b>] [flags]

DESCRIPTION
  Line diff between two document versions WITHOUT pulling both full bodies into context. Two modes: pass two documentIds (<a> old, <b> new), or --type <name> to diff that type's newest DRAFT against its current ACTIVE version (i.e. what would change if you publish the draft). Returns per-side metadata + added/removed line counts + a compact unified diff (long unchanged runs collapse).
  Auth: requires login (any authenticated user).

ARGUMENTS
  <a> NUMBER    Old documentId (omit when using --type) (optional)
  <b> NUMBER    New documentId (omit when using --type) (optional)

FLAGS
  --type STRING    Diff newest DRAFT vs current ACTIVE of this type (instead of <a> <b>)
  --owner NUMBER    ownerAsiakasId scope for --type resolution (1349 = BetoniJerry); only valid with --type

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  {a: {documentId, typeName, version, status, contentLength}, b: {...}, sameContent, addedLines, removedLines, unified}

ERRORS (stderr, exit non-zero)
  exit 4  Neither two documentIds nor --type supplied (or both), or --owner without --type → pass <a> <b> OR --type <name>
  exit 5 (HTTP 404)  documentId / type's draft or active not found → check ib legal versions <typeName>
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

SEE ALSO
  ib legal versions, ib legal drafts, ib legal get

EXAMPLES
  ib legal diff 4 38
  ib legal diff --type TOS
  ib legal diff --type BETONIJERRY_TOS --owner 1349
"
`;

