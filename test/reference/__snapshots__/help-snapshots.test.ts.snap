exports[`Help snapshots — contract stability > help for ib jerry admin detail matches snapshot 1`] = `
"USAGE
  ib jerry admin detail [flags]

DESCRIPTION
  Company Jerry drill-down: people by role (admins/tarjousAdmins/pumpparit), vehicles, and each sijainti's Jerry enrolment status (GET /api/admin/jerry-companies/:asiakasId/detail). System-admin only.
  Permissions: requires isSystemAdmin.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --asiakasId NUMBER    Positional — company asiakasId

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json

OUTPUT (JSON, stdout)
  { admins:[{personId,name}], tarjousAdmins:[…], pumpparit:[…], vehicles:[{vehicleId,vehicleRegNo}], sijainnit:[{sijaintiId,name,isJerry}] }

ERRORS (stderr, exit non-zero)
  400  Invalid asiakasId      → pass a numeric asiakasId
  403  Not a system admin     → use a system-admin token
  401  Token expired          → ib auth refresh
  500  Backend error          → retry with --verbose

EXAMPLES
  ib jerry admin detail 1402
"
`;

exports[`Help snapshots — contract stability > help for ib jerry admin disable matches snapshot 1`] = `
"USAGE
  ib jerry admin disable [flags]

DESCRIPTION
  Disable the BetoniJerry module for a company — clears BOTH isPumppuToimittaja and the HAS_JERRY setting (POST /api/admin/jerry-companies/:asiakasId/disable). System-admin only. Requires --reason.
  Permissions: requires isSystemAdmin.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --asiakasId NUMBER    Positional — company asiakasId
  --reason STRING    Audit-log reason (REQUIRED)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json

OUTPUT (JSON, stdout)
  { success: true } or { dryRun: true, wouldUpdate: { asiakasId, enable: false } }

ERRORS (stderr, exit non-zero)
  400  Invalid asiakasId      → pass a numeric asiakasId
  403  Not a system admin     → use a system-admin token
  404  Company not found      → verify asiakasId
  401  Token expired          → ib auth refresh
  500  Backend error          → retry with --verbose

EXAMPLES
