exports[`Help snapshots — contract stability > help for ib schema dump matches snapshot 1`] = `
"USAGE
  ib schema dump [flags]

DESCRIPTION
  Structural map of the whole dbo schema — all tables with column names and types, FK edges, view names, and proc signatures. No proc/view bodies (use \`schema proc\`/\`schema view\` for those). Developer-only.
  Permissions: requires developer access (isSystemAdmin or isDeveloper).
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json

OUTPUT (JSON, stdout)
  { tables:[{name,columns}], foreignKeys:[{table,column,refTable,refColumn}], views:[{name}], procs:[{name,type,parameters}] }

ERRORS (stderr, exit non-zero)
  401  Token expired          → ib auth refresh
  403  Not a developer        → run \`ib auth whoami\`; if not a developer, \`ib auth login\` as a developer account (same person re-login won't grant it). Gate is server-side — a new DB flag only applies once --endpoint's backend is redeployed.
  500  Backend error          → retry with --verbose

EXAMPLES
  ib schema dump
"
`;

exports[`Help snapshots — contract stability > help for ib schema proc matches snapshot 1`] = `
