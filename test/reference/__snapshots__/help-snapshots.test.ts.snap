exports[`Help snapshots — contract stability > help for ib commands matches snapshot 1`] = `
"USAGE
  ib commands [<domain>] [flags]

DESCRIPTION
  Offline command discovery from the spec catalogue. No args = compact DOMAIN INDEX (~5 KB: every domain with leaf count, glossary blurb, runnable command paths). A domain arg, a filter flag, or --all returns the flat per-command list { command, description, permissions, isWrite }. Lighter than \`ib reference dump\` (the full surface). No auth, no network.
  Auth: none (public).

ARGUMENTS
  <domain> STRING    Only commands in this domain (the token after \`ib\`, e.g. keikka, jerry). Unknown domain exits 4 listing valid domains. (optional)

FLAGS
  --mutations BOOLEAN    Only commands that write (carry write-safety flags)
  --reads BOOLEAN    Only read-only commands (no writes)
  --permission STRING    Only commands whose required permissions contain this substring
  --all BOOLEAN    Full flat list of every command (~43 KB at 149 leaves). Default (no args) is the domain index.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  no args: { hint, items:[{ domain, count, description|null, commands:["keikka list", ...] }], nextCursor:null, count } (domain index) | with <domain> / --all / filters: { items: [{ command, description, permissions: string[], isWrite: boolean }], nextCursor: null, count }

ERRORS (stderr, exit non-zero)
  exit 4  Bad flag combo         → --mutations and --reads are mutually exclusive
  exit 4  Unknown domain         → run \`ib commands\` (no arg) to see valid domains

EXAMPLES
  ib commands
  ib commands keikka
  ib commands --all
  ib commands --mutations
  ib commands --reads
  ib commands --permission auth.page.vehicle
  ib commands --mutations | jq '.items[].command'
"
`;

