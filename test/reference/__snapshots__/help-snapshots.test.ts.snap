  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  ListEnvelope<{ pumppuOfferId, status, priceCents, vatPercent, validUntil, asiakasNimi, ytunnus, providerDistanceKm, companyDescription, jerryContactName?, jerryContactPhone?, openingHours? }>

ERRORS (stderr, exit non-zero)
  exit 5 (HTTP 404)  Request not found / not yours → verify requestId
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib jerry request offers 4012
  ib jerry request offers 4012 --pretty
"
`;

exports[`Help snapshots — contract stability > help for ib keikka create matches snapshot 1`] = `
"USAGE
  ib keikka create [flags]

DESCRIPTION
  Create a new keikka. The body is forwarded verbatim to POST /api/keikka/newKeikka — see the backend route for required fields.
  Permissions: requires auth.page.grid.tilaus.edit.

FLAGS
  --body JSON    JSON object with the new keikka fields

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { keikkaId, ...echoed fields } (raw backend response)

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Validation failed      → fix --body fields
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.grid.tilaus.edit
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib keikka create --body '{"asiakasId":1349,"pvm":"2026-06-01"}' --reason 'manual booking'
  ib keikka create --body '{...}' --dry-run
"
`;

