exports[`Help snapshots — contract stability > help for ib sijainti update matches snapshot 1`] = `
"USAGE
  ib sijainti update [flags]

DESCRIPTION
  Update a sijainti (POST /api/geocode/updateSijainti). sijaintiId via --id or in --body. Provide typed flags or --body JSON; typed flags win over --body.
  Permissions: requires auth.page.sijainnit.edit.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --body JSON    JSON object with fields to update (optional if typed flags given)
  --id NUMBER    Target sijaintiId (or include sijaintiId in --body)
  --name STRING    sijaintiNimi
  --address STRING    sijaintiOsoite1 (street)
  --type NUMBER    sijaintiTypeId
  --lat NUMBER    Latitude
  --lng NUMBER    Longitude

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json

OUTPUT (JSON, stdout)
  { ok: true, ... } (raw backend response)

ERRORS (stderr, exit non-zero)
  400  Validation failed      → fix --body fields
  404  Sijainti not found     → verify sijaintiId
  401  Token expired          → ib auth refresh
  403  Permission denied      → check auth.page.sijainnit.edit
  500  Backend error          → retry with --verbose

EXAMPLES
  ib sijainti update --id 42 --name "Renamed depot"
  ib sijainti update --body '{"sijaintiId":42,"sijaintiNimi":"Renamed depot"}'
"
`;

exports[`Help snapshots — contract stability > help for ib vehicle create matches snapshot 1`] = `
"USAGE
  ib vehicle create [flags]

DESCRIPTION
  Create a vehicle. Two-step backend flow (POST /api/vehicle/new then /save); ownerAsiakasId from JWT. Dry-run previews via /new without inserting.
  Permissions: requires auth.page.vehicle.edit.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --reg STRING    Registration number (vehicleRegNo)
  --name STRING    Display name (vehicleNimi)
  --no NUMBER    Fleet number (vehicleNo)
  --type NUMBER    vehicleTypeId (see ib vehicle types)
  --memo STRING    Free-text memo
  --default-driver NUMBER    Default driver personId
  --capacity NUMBER    Concrete capacity in m3 (vehicleM3)
  --asiakas NUMBER    Owning asiakasId (defaults to active company)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json

OUTPUT (JSON, stdout)
  { vehicleId, ... } (raw backend save response) | { dryRun, wouldCreate }

ERRORS (stderr, exit non-zero)
  400  Validation failed      → fix the field flags
  401  Token expired          → ib auth refresh
  403  Permission denied      → check auth.page.vehicle.edit
  500  Backend error          → retry with --verbose

EXAMPLES
  ib vehicle create --reg ABC-123 --type 1 --capacity 7.5 --reason 'new truck'
  ib vehicle create --reg ABC-123 --dry-run
"
`;

