exports[`Help snapshots — contract stability > help for ib worksite person add matches snapshot 1`] = `
"USAGE
  ib worksite person add [flags]

DESCRIPTION
  Attach a person to a worksite (tyomaaPerson). Requires --reason.
  Permissions: requires auth.page.tyomaa.edit.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --worksite NUMBER    Target tyomaaId (REQUIRED)
  --person NUMBER    Target personId (REQUIRED)
  --contact-type NUMBER    contactPersonTypeId (default: 1)
  --reason STRING    Audit-log reason (REQUIRED)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json

OUTPUT (JSON, stdout)
  { added: { tyomaaId, personId } }

ERRORS (stderr, exit non-zero)
  401  Token expired          → ib auth refresh
  403  Permission denied      → check auth.page.tyomaa.edit
  500  Backend error          → retry with --verbose

EXAMPLES
  ib worksite person add --worksite 99 --person 5351 --reason "assign foreman"
"
`;

