exports[`Help snapshots — contract stability > help for ib customer create matches snapshot 1`] = `
"USAGE
  ib customer create [flags]

DESCRIPTION
  Create a customer. Typed flags assemble the createY body (yTunnus REQUIRED); --from-prh prefills name+yTunnus from the PRH registry; --body raw JSON overrides flags. Returns the flat customer shape via re-fetch.
  Permissions: requires auth.page.asiakas.edit.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --name STRING    Customer name (asiakasNimi)
  --ytunnus STRING    Business ID (yTunnus) — required unless --from-prh/--body supplies it
  --email STRING    Invoicing email (laskutusEmail)
  --short-name STRING    Short display name (asiakasShortNimi)
  --from-prh STRING    Prefill name + yTunnus from PRH for this business ID
  --body JSON    Raw JSON body (overrides typed flags)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json

OUTPUT (JSON, stdout)
  flat customer { asiakasId, name, yTunnus, type, address, city, email, contactPersonId, shortName, comment } (or wouldCreate on --dry-run)

ERRORS (stderr, exit non-zero)
  400  Missing yTunnus / validation → pass --ytunnus or --from-prh
  401  Token expired          → ib auth refresh
  403  Permission denied      → check auth.page.asiakas.edit
  500  Backend error          → retry with --verbose

EXAMPLES
  ib customer create --from-prh 0145937-9 --email billing@x.fi --reason onboard
  ib customer create --name 'Example Oy' --ytunnus 1234567-8
"
`;

exports[`Help snapshots — contract stability > help for ib customer delete matches snapshot 1`] = `
"USAGE
  ib customer delete [flags]

DESCRIPTION
  Delete a customer (asiakas). Requires --reason; --dry-run available.
  Permissions: requires auth.page.asiakas.edit.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --reason STRING    Audit-log reason (REQUIRED)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json

OUTPUT (JSON, stdout)
  { deleted: number } or { dryRun: true, wouldDelete: number }

ERRORS (stderr, exit non-zero)
  404  Customer not found     → verify asiakasId
  401  Token expired          → ib auth refresh
  403  Permission denied      → check auth.page.asiakas.edit
  500  Backend error          → retry with --verbose

EXAMPLES
  ib customer delete 9001 --reason "lifecycle cleanup"
"
`;

