exports[`Help snapshots — contract stability > help for ib worksite update matches snapshot 1`] = `
"USAGE
  ib worksite update <tyomaaId> [flags]

DESCRIPTION
  Update a worksite via POST /api/tyomaa/set (ownerAsiakasId derived from the session JWT; yyyymmdd defaults to today).
  Permissions: requires auth.page.tyomaa.edit.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

ARGUMENTS
  <tyomaaId> NUMBER    tyomaaId to update (required)

FLAGS
  --body JSON    JSON object with the fields to update
  --yyyymmdd DATE    Effective date segment YYYYMMDD (defaults to today) (default: today)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  { ok: true, ... } (raw backend response)

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Validation failed      → fix --body fields
  exit 5 (HTTP 404)  Worksite not found     → verify tyomaaId
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.tyomaa.edit
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib worksite update 99 --body '{"comment":"Pickup at gate B"}'
"
`;
