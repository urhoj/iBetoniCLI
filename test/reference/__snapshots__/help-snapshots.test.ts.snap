"
`;

exports[`Help snapshots — contract stability > help for ib customer modules matches snapshot 1`] = `
"USAGE
  ib customer modules [<asiakasId>] [flags]

DESCRIPTION
  Report or toggle a customer's roolit + module flags.
  Permissions: requires company admin on the target tenant (system admin = any tenant).

ARGUMENTS
  <asiakasId> NUMBER    asiakasId to report/modify (or pass --asiakas) (optional)

FLAGS
  --asiakas NUMBER    Target asiakasId (alias for the positional)
  --set STRING    Comma-separated field keys to turn ON
  --unset STRING    Comma-separated field keys to turn OFF

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  report: { asiakasId, roolit:{...}, modules:{...} } | write: { asiakasId, applied:{ set, unset, dryRun }, state:{ roolit, modules } }

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Unknown field key, or key in both --set and --unset → use only: pumppu/jerry/henkilot/sijainnit/ajoneuvot/tiedostot/weather/lomaseuranta/shareorders
  exit 3 (HTTP 403)  Not an admin of this tenant → use a system-admin token, or an admin of the owner company
  exit 5 (HTTP 404)  Customer not found     → verify asiakasId
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Field keys: pumppu (isPumppuToimittaja), jerry, henkilot, sijainnit, ajoneuvot, tiedostot, weather, lomaseuranta, shareorders.
  - Without --set/--unset it is a read-only report (GET /api/cli/customer/modules/:asiakasId); with them it routes pumppu → POST /api/asiakas/setRoolit and modules → POST /api/asiakas/settings/save.
  - The target accepts either the positional <asiakasId> or --asiakas <id> (same flag as the rest of customer/*); pass one.

EXAMPLES
  ib customer modules 1349
  ib customer modules --asiakas 1349 --set jerry,weather,pumppu --reason 'enable operator features'
  ib customer modules 1349 --unset shareorders --dry-run
"
`;

exports[`Help snapshots — contract stability > help for ib customer operator matches snapshot 1`] = `
"USAGE
  ib customer operator [<asiakasId>] [flags]

DESCRIPTION
  Verify or provision the full operator preset — all 9 operator flags at once (pumppu + the 8 modules). Default (no flag): verify, exit 0 iff every flag is on else exit 1 (CI-gateable). --set turns all 9 on; --reset turns all 9 off. System-admin can run cross-tenant.
  Permissions: requires company admin on the target tenant (system admin = any tenant).

ARGUMENTS
  <asiakasId> NUMBER    asiakasId to verify/provision (or pass --asiakas) (optional)

FLAGS
  --asiakas NUMBER    Target asiakasId (alias for the positional)
  --set BOOLEAN    Turn ALL 9 operator flags ON
  --reset BOOLEAN    Turn ALL 9 operator flags OFF

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  verify: { asiakasId, allSet, flags:{ pumppu, jerry, … }, missing:[…] } (exit 1 when allSet=false) | set/reset: { asiakasId, applied:{ set, unset, dryRun }, state }

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  --set and --reset both given → pass at most one of --set / --reset
  exit 3 (HTTP 403)  Not an admin of this tenant → use a system-admin token, or an admin of the owner company
  exit 5 (HTTP 404)  Customer not found     → verify asiakasId
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib customer operator 1349
  ib customer operator --asiakas 1349 --set --reason 'onboard operator'
  ib customer operator 1349 --reset --reason 'offboard operator'
"
`;

exports[`Help snapshots — contract stability > help for ib customer person add matches snapshot 1`] = `
"USAGE
  ib customer person add [flags]

DESCRIPTION
  Attach a person to a customer (asiakasPerson). Requires --reason.
  Permissions: requires auth.page.asiakas.edit.

FLAGS
  --asiakas NUMBER    Target asiakasId (REQUIRED)
  --person NUMBER    Target personId (REQUIRED)
  --contact-type NUMBER    contactPersonTypeId — membership link type (1=pumppari [default], 2=order-email recipient, 3=manual, 5=auto-from-keikka) (default: 1)
  --reason STRING    Audit-log reason (X-Action-Reason); REQUIRED

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { added: { asiakasId, personId } } or { dryRun: true, wouldCreate: { asiakasId, personId, contactPersonTypeId } }

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Company limit (26) reached → remove an existing link first
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.asiakas.edit
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib customer person add --asiakas 26 --person 5351 --contact-type 1 --reason "onboard driver"
"
`;

exports[`Help snapshots — contract stability > help for ib customer person list matches snapshot 1`] = `
"USAGE
  ib customer person list [<asiakasId>] [flags]

DESCRIPTION
  List persons attached to a customer. \`--role\` filters by role name; the per-row \`roleTypeId\` only echoes that filter (null when unfiltered — the base membership row), so it is NOT the person's role set. For the FULL per-company roles pass \`--include-roles\` (adds permissionRoles[]) or use \`ib person role list\`.
  Permissions: requires auth.page.asiakas.read.

ARGUMENTS
  <asiakasId> NUMBER    asiakasId (or pass --asiakas, like person add/remove) (optional)

FLAGS
  --asiakas NUMBER    Target asiakasId (alias for the positional; same flag as person add/remove)
  --role STRING    Filter by role name (e.g. keikkaHandler)
  --include-roles BOOLEAN    Add permissionRoles[] (full per-company role names) to each person — N extra GETs, opt-in

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  ListEnvelope<{ personId, name, email, roleTypeId: number|null, permissionRoles?: string[] }>

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Unknown role name      → see ROLE_TYPEID_BY_NAME in @ibetoni/constants
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.asiakas.read
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

SEE ALSO
  ib person role list

EXAMPLES
  ib customer person list 26
  ib customer person list --asiakas 26 --role keikkaHandler
  ib customer person list 27 --include-roles
"
`;

