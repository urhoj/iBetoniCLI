// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Help snapshots — contract stability > help for ib auth login matches snapshot 1`] = `
"USAGE
  ib auth login [flags]

DESCRIPTION
  Open the system browser to authorize this CLI via OAuth 2.1 + PKCE and persist credentials to ~/.ibetoni/credentials.json (mode 0600).
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --endpoint URL    API endpoint to authorize against (default: https://api.ibetoni.fi)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json

OUTPUT (JSON, stdout)
  stderr: 'Logged in as <email> at <company>.'; credentials file written

ERRORS (stderr, exit non-zero)
  2  OAuth flow failed      → retry; check network / browser
  500  Backend error          → retry later

EXAMPLES
  ib auth login
  ib auth login --endpoint https://api-staging.ibetoni.fi
"
`;

exports[`Help snapshots — contract stability > help for ib auth logout matches snapshot 1`] = `
"USAGE
  ib auth logout [flags]

DESCRIPTION
  Revoke the refresh token server-side (best-effort) and delete the local credentials file.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json

OUTPUT (JSON, stdout)
  no stdout output; exit 0 on success

ERRORS (stderr, exit non-zero)
  1  I/O error              → check file permissions

EXAMPLES
  ib auth logout
"
`;

exports[`Help snapshots — contract stability > help for ib auth refresh matches snapshot 1`] = `
"USAGE
  ib auth refresh [flags]

DESCRIPTION
  Manually refresh the JWT against /api/auth/refresh-token. Automatic refresh-on-401 also happens in the API client.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json

OUTPUT (JSON, stdout)
  { ok: true }

ERRORS (stderr, exit non-zero)
  2  Refresh failed         → ib auth login to re-authenticate

EXAMPLES
  ib auth refresh
"
`;

exports[`Help snapshots — contract stability > help for ib auth switch matches snapshot 1`] = `
"USAGE
  ib auth switch [flags]

DESCRIPTION
  Switch the active company. Issues a new JWT bound to the target ownerAsiakasId and persists it.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --to NUMBER    Target asiakasId to switch to

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json

OUTPUT (JSON, stdout)
  { ok: true, activeCompany: { asiakasId, name } }

ERRORS (stderr, exit non-zero)
  2  Not logged in          → ib auth login
  403  No access to target    → verify ownership via \`ib company list\`

EXAMPLES
  ib auth switch --to 1349
"
`;

