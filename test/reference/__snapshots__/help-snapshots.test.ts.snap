exports[`Help snapshots — contract stability > help for ib doctor matches snapshot 1`] = `
"USAGE
  ib doctor [flags]

DESCRIPTION
  Aggregated 'is my setup working' health check, and the first-contact orientation for MCP / \`/api/cli/exec\` callers (where the \`auth\` group — incl. \`auth whoami\` — is denied). Derives identity + tier + switchable companies from the active JWT (works for both file- and IB_TOKEN-sessions), reports token expiry, pings the public /api/version for connectivity + which build is live, and does ONE authenticated read to prove the token is accepted by this endpoint. Read-only. Exits 1 when the aggregate \`ok\` is false.
  Auth: requires login (any authenticated user).

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { ok:boolean, cli, endpoint, readOnly, auth:{ personId, email, tier:'developer'|'admin'|'standard', ownerAsiakasId, ownerAsiakasName, companies:{ asiakasId, roles }[], issuedFor, tokenExp, tokenExpired, impersonating?:{actorPersonId,sessionId} }, connectivity:VersionReport, authProbe:{ ok, status?, error? } } — \`tier\` = capability/discovery gate; \`companies\` = \`company switch\` targets; \`impersonating\` present only when the token acts as another person.

ERRORS (stderr, exit non-zero)
  exit 1  Not healthy            → inspect connectivity / authProbe / tokenExpired in the report
  exit 2  Not logged in          → ib auth login (or set IB_TOKEN)

EXAMPLES
  ib doctor
  ib doctor --endpoint https://api-staging.ibetoni.fi
"
`;

exports[`Help snapshots — contract stability > help for ib glossary delete matches snapshot 1`] = `
"USAGE
  ib glossary delete <term> [flags]

DESCRIPTION
  Delete a glossary entry (developer only).
  Auth: requires login (any authenticated user).

ARGUMENTS
  <term> STRING    Canonical term (required)

FLAGS
  (none)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { deleted: 0|1 } — rows removed; or { dryRun: true, term, wouldDelete: <entry>|null } with --dry-run

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Not a developer        → Developer access required

NOTES
  - --dry-run resolves CLIENT-SIDE: it previews the entry that WOULD be deleted (via the miss-free ?search= endpoint) and never issues the DELETE — safe even before the backend guard deploys (the backend DELETE route ignored X-Dry-Run before this fix, so a --dry-run silently destroyed the entry).

EXAMPLES
  ib glossary delete obsolete-term --reason cleanup
  ib glossary delete obsolete-term --dry-run
"
`;

exports[`Help snapshots — contract stability > help for ib glossary import matches snapshot 1`] = `
"USAGE
  ib glossary import <file> [flags]

DESCRIPTION
  Bulk create/update glossary entries from a JSON array file (developer only). Avoids shell argv mangling of Finnish ä/ö.
  Auth: requires login (any authenticated user).

ARGUMENTS
  <file> STRING    JSON array file of {term, definition, synonyms?, relatedCommands?, relatedEntity?, domain?} objects (or - for stdin) (required)

FLAGS
  --update-only BOOLEAN    Only update existing terms; never insert

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { results: [{term, ok, error?}], ok, failed }

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Not a developer        → Developer access required
  exit 4  File is not valid JSON or root is not an array → Check the file path and JSON syntax

NOTES
  - Each entry must have a \`term\` field; entries missing it are counted as failed.
  - Synonyms and relatedCommands may be arrays (arrays are accepted and converted to a comma list internally) or comma-separated strings.
  - Avoids shell argv mangling of Finnish ä/ö — pass UTF-8 JSON instead of quoting on the command line.

EXAMPLES
  ib glossary import terms.json --reason "bulk groom"
  echo '[{"term":"loma","definition":"Vapaapaiva"}]' | ib glossary import - --reason "test"
"
`;

exports[`Help snapshots — contract stability > help for ib glossary lint matches snapshot 1`] = `
"USAGE
  ib glossary lint [flags]

DESCRIPTION
  Audit entries: dead relatedCommands, near-duplicate terms, empty fields (developer only).
  Auth: requires login (any authenticated user).

FLAGS
  --strict BOOLEAN    Exit 1 if any warn-level finding exists (for CI)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  ListEnvelope<{ term, issue, detail, severity }>

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Not a developer        → Developer access required

EXAMPLES
  ib glossary lint
"
`;

exports[`Help snapshots — contract stability > help for ib glossary list matches snapshot 1`] = `
"USAGE
  ib glossary list [flags]

DESCRIPTION
  List glossary entries; --search filters by term/definition/synonym, --stalest orders least-recently-reviewed first.
  Auth: requires login (any authenticated user).

FLAGS
  --search STRING    Filter by substring
  --stalest NUMBER    Return up to N entries, stalest first
  --domain STRING    Filter to a domain (exact match)
  --related STRING    Filter to terms whose relatedCommands contain this substring
  --terms-only BOOLEAN    Return only {term, synonyms} per entry — the cheap INDEX view (strips definitions); use to discover which terms exist.
  --needs-review BOOLEAN    Only terms still needing grooming: aiConfidence below the threshold (or unassessed) AND not parked, oldest-first.
  --max-confidence NUMBER    Threshold for --needs-review (default 90).

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { items:[{term,synonyms,definition,relatedCommands:[{command,summary}],relatedEntity,domain,lastReviewed,runs,aiConfidence,needsHumanReview}], count, truncated? }

ERRORS (stderr, exit non-zero)
  exit 2  Not authenticated      → Run \`ib auth login\`

NOTES
  - --terms-only is client-side: it strips each row to {term, synonyms} after the server-side filters apply. Use it instead of a full list to discover terms cheaply (the full list returns every definition).

EXAMPLES
  ib glossary list
  ib glossary list --search puomi
  ib glossary list --stalest 10
  ib glossary list --domain vacation
  ib glossary list --terms-only
  ib glossary list --needs-review
"
`;

exports[`Help snapshots — contract stability > help for ib glossary lookup matches snapshot 1`] = `
"USAGE
  ib glossary lookup <term> [flags]

DESCRIPTION
  Resolve a Finnish/colloquial term or synonym to its definition + related commands (DB-backed). Exit 5 if undefined — the miss is recorded for the groomer.
  Auth: requires login (any authenticated user).

ARGUMENTS
  <term> STRING    A word or synonym, e.g. pumppari (required)

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  single term: { term, synonyms[], definition, relatedCommands:[{command,summary}], relatedEntity } | batch (a,b,c): ListEnvelope<{ term, found, entry }>

ERRORS (stderr, exit non-zero)
  exit 5 (HTTP 404)  No entry for the term  → Try \`ib glossary list --search <term>\`; the miss is queued for definition
  exit 2  Not authenticated      → Run \`ib auth login\`

NOTES
  - Comma-separated terms (a,b,c) run a batch lookup returning a ListEnvelope of {term,found,entry}; a single term keeps the single-entry shape.

EXAMPLES
  ib glossary lookup pumppari
  ib glossary lookup betoniasema
  ib glossary lookup loma,saikku,pyhä
"
`;

