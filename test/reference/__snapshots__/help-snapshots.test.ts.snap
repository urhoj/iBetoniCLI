exports[`Help snapshots — contract stability > help for ib person role revoke matches snapshot 1`] = `
"USAGE
  ib person role revoke [flags]

DESCRIPTION
  Revoke a per-company role from a person (idempotent: { removed:0 } when absent). Looks up the asiakasPersonSettingId then DELETEs it. --dry-run previews via the backend ({ dryRun:true, wouldDelete }).
  Permissions: requires company admin on the target tenant (tier per role).
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --personId NUMBER    Positional — personId
  --role STRING    Role name (REQUIRED)
  --asiakas NUMBER    Target asiakasId (REQUIRED)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json

OUTPUT (JSON, stdout)
  { removed: 1 } | { removed: 0 } (absent) | { dryRun:true, wouldDelete:{ asiakasPersonSettingId }, validation }

ERRORS (stderr, exit non-zero)
  400  Unknown role           → use a name from ROLE_TYPEID_BY_NAME
  403  Not a tenant admin     → use a system-admin token or a tenant admin
  401  Token expired          → ib auth refresh
  500  Backend error          → retry with --verbose

EXAMPLES
  ib person role revoke 5351 --role keikkaHandler --asiakas 26 --reason rotation
"
`;

