exports[`Help snapshots — contract stability > help for ib worksite update matches snapshot 1`] = `
"USAGE
  ib worksite update [flags]

DESCRIPTION
  Update a worksite via POST /api/tyomaa/set/:ownerAsiakasId/:tyomaaId/:yyyymmdd.
  Permissions: requires auth.page.tyomaa.edit.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --tyomaaId NUMBER    Positional — tyomaaId to update
  --body JSON    JSON object with the fields to update
  --date DATE    Effective date (YYYYMMDD; today by default) (default: today)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json

OUTPUT (JSON, stdout)
  { ok: true, ... } (raw backend response)

ERRORS (stderr, exit non-zero)
  400  Validation failed      → fix --body fields
  404  Worksite not found     → verify tyomaaId
  401  Token expired          → ib auth refresh
  403  Permission denied      → check auth.page.tyomaa.edit
  500  Backend error          → retry with --verbose

EXAMPLES
  ib worksite update 99 --body '{"comment":"Pickup at gate B"}'
"
`;
