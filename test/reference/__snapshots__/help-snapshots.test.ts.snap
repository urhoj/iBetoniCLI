  exit 5 (HTTP 404)  Worksite not found     → verify tyomaaId
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.tyomaa.edit
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib worksite refresh-location 99 --reason "address corrected"
"
`;

exports[`Help snapshots — contract stability > help for ib worksite search matches snapshot 1`] = `
"USAGE
  ib worksite search <query> [flags]

DESCRIPTION
  Free-text worksite search (POST /api/tyomaa/search). The query full-text-matches the worksite name, ALL FOUR address lines (street / line 2 / postal code / city), driving instructions, memo, formatted address, worksite number AND the contact person's name / phone / email — so a street fragment like 'Mannerheimintie' finds the worksite. Scoped to the active company. Safe under --read-only (sent as a read request — a tenant-scoped read over POST, distinct from a meta/diagnostic call — so it does NOT trip the read-only lock or the acting-as write line).
  Permissions: requires auth.page.tyomaa.read.

ARGUMENTS
  <query> STRING    search string (required)

FLAGS
  --limit NUMBER    Max results (backend caps at 100) (default: 50)
  --my-companies BOOLEAN    Search across every company you belong to (customer/worksite/person)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  ListEnvelope<{ tyomaaId, name, tyomaaNum, address, address2, postalCode, city, formattedAddress, coords:{lat,lng}|null, drivingInstructions, comment }>

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.tyomaa.read
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib worksite search Mannerheimintie
  ib worksite search 'Jokiniementie 13' --limit 10
"
`;

exports[`Help snapshots — contract stability > help for ib worksite set-geofence matches snapshot 1`] = `
"USAGE
  ib worksite set-geofence <tyomaaId> [flags]

DESCRIPTION
  Set a worksite geofence radius in metres (1-10000).
  Permissions: requires auth.page.tyomaa.edit.

ARGUMENTS
  <tyomaaId> NUMBER    tyomaaId (required)

FLAGS
  --radius NUMBER    Geofence radius in metres (1-10000)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { success: true }

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Radius out of range    → use 1-10000
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.tyomaa.edit
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib worksite set-geofence 99 --radius 300
"
`;

exports[`Help snapshots — contract stability > help for ib worksite update matches snapshot 1`] = `
"USAGE
  ib worksite update <tyomaaId> [flags]

DESCRIPTION
  Update a worksite via POST /api/tyomaa/set (ownerAsiakasId derived from the session JWT; yyyymmdd defaults to today).
  Permissions: requires auth.page.tyomaa.edit.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

ARGUMENTS
  <tyomaaId> NUMBER    tyomaaId to update (required)

FLAGS
  --body JSON    JSON object with the fields to update
  --yyyymmdd DATE    Effective date segment YYYYMMDD (defaults to today) (default: today)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { ok: true, ... } (raw backend response)

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Validation failed      → fix --body fields
  exit 5 (HTTP 404)  Worksite not found     → verify tyomaaId
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.tyomaa.edit
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib worksite update 99 --body '{"comment":"Pickup at gate B"}'
"
`;
