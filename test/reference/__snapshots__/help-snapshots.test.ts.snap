exports[`Help snapshots — contract stability > help for ib customer list matches snapshot 1`] = `
"USAGE
  ib customer list [flags]

DESCRIPTION
  List customers (asiakkaat).
  Permissions: requires auth.page.asiakas.read.

FLAGS
  --limit NUMBER    Max rows for the unbounded list (capped at 500). Ignored when --ids is given. (default: 100)
  --cursor STRING    Pagination cursor
  --full BOOLEAN    Return full customer fields + companyDescription (not just id/name/ytunnus/type)
  --ids STRING    Comma-separated asiakasIds to return ALL of (max 1000) — preferred for targeted/incremental fetches
  --include STRING    Expand each row with per-customer arrays: contacts and/or sijainnit (CSV; best with --full)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  ListEnvelope<{ asiakasId, name, yTunnus, type }> + truncated:boolean · with --full the items add { address, postalCode, city, email, contactPersonId, shortName, comment, companyDescription } · with --include each item adds contacts:[{personId,name,phone,email,contactPersonTypeId}] and/or sijainnit:[{sijaintiId,name,lyh,address,sijaintiTypeId,maxDeliveryDistance,jerryActiveUntil}] · with --ids the response adds missing:[{asiakasId, reason:'not_owned'|'not_found'}] for requested ids that didn't return

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.asiakas.read
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Scope: regular users see their own tenant + their own company row; SYSTEM ADMINS list across ALL tenants (incl. cross-tenant --ids).
  - --full returns every flat-customer field + the jerry companyDescription in one call (diff a whole tenant without N×\`customer get\`).
  - --ids 1,2,3 restricts to specific asiakasIds and returns ALL of them (NOT capped at the default 100 — bounded by the ids list, max 1000) — the efficient way to refresh only the rows you care about.
  - Without --ids the list is capped (default 100 / max 500) and \`truncated:true\` flags when you hit the cap (narrow with --ids or raise --limit).

EXAMPLES
  ib customer list
  ib customer list --limit 50 --pretty
  ib customer list --full
  ib customer list --ids 26,42,1349 --full
  ib customer list --ids 26,42 --full --include contacts,sijainnit
"
`;

exports[`Help snapshots — contract stability > help for ib customer modules matches snapshot 1`] = `
"USAGE
  ib customer modules <asiakasId> [flags]

DESCRIPTION
  Report or toggle a customer's roolit + module flags.
  Permissions: requires company admin on the target tenant (system admin = any tenant).

ARGUMENTS
  <asiakasId> NUMBER    asiakasId to report/modify (required)

FLAGS
  --set STRING    Comma-separated field keys to turn ON
  --unset STRING    Comma-separated field keys to turn OFF

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  report: { asiakasId, roolit:{...}, modules:{...} } | write: { asiakasId, applied:{ set, unset, dryRun }, state:{ roolit, modules } }

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Unknown field key, or key in both --set and --unset → use only: pumppu/jerry/henkilot/sijainnit/ajoneuvot/tiedostot/weather/lomaseuranta/shareorders
  exit 3 (HTTP 403)  Not an admin of this tenant → use a system-admin token, or an admin of the owner company
  exit 5 (HTTP 404)  Customer not found     → verify asiakasId
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Field keys: pumppu (isPumppuToimittaja), jerry, henkilot, sijainnit, ajoneuvot, tiedostot, weather, lomaseuranta, shareorders.
  - Without --set/--unset it is a read-only report (GET /api/cli/customer/modules/:asiakasId); with them it routes pumppu → POST /api/asiakas/setRoolit and modules → POST /api/asiakas/settings/save.

EXAMPLES
  ib customer modules 1349
  ib customer modules 1349 --set jerry,weather,pumppu --reason 'enable operator features'
  ib customer modules 1349 --unset shareorders --dry-run
"
`;

exports[`Help snapshots — contract stability > help for ib customer operator matches snapshot 1`] = `
"USAGE
  ib customer operator <asiakasId> [flags]

DESCRIPTION
  Verify or provision the full operator preset — all 9 operator flags at once (pumppu + the 8 modules). Default (no flag): verify, exit 0 iff every flag is on else exit 1 (CI-gateable). --set turns all 9 on; --reset turns all 9 off. System-admin can run cross-tenant.
  Permissions: requires company admin on the target tenant (system admin = any tenant).

ARGUMENTS
  <asiakasId> NUMBER    asiakasId to verify/provision (required)

FLAGS
  --set BOOLEAN    Turn ALL 9 operator flags ON
  --reset BOOLEAN    Turn ALL 9 operator flags OFF

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  verify: { asiakasId, allSet, flags:{ pumppu, jerry, … }, missing:[…] } (exit 1 when allSet=false) | set/reset: { asiakasId, applied:{ set, unset, dryRun }, state }

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  --set and --reset both given → pass at most one of --set / --reset
  exit 3 (HTTP 403)  Not an admin of this tenant → use a system-admin token, or an admin of the owner company
  exit 5 (HTTP 404)  Customer not found     → verify asiakasId
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib customer operator 1349
  ib customer operator 1349 --set --reason 'onboard operator'
  ib customer operator 1349 --reset --reason 'offboard operator'
"
`;

exports[`Help snapshots — contract stability > help for ib customer person add matches snapshot 1`] = `
"USAGE
