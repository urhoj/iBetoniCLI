exports[`Help snapshots — contract stability > help for ib customer settings matches snapshot 1`] = `
"USAGE
  ib customer settings [<asiakasId>] [flags]

DESCRIPTION
  Report or toggle ALL asiakasSettings (every canonical ASIAKAS_SETTING_TYPE_IDS name) plus pumppu. Without --set/--unset it is a read-only report. Names are case-insensitive; the 8 module aliases (jerry, weather, …) and pumppu are also accepted. Superset of \`customer modules\`.
  Permissions: requires company admin on the target tenant (system admin = any tenant).

ARGUMENTS
  <asiakasId> NUMBER    asiakasId (or pass --asiakas) (optional)

FLAGS
  --asiakas NUMBER    Target asiakasId (alias for the positional)
  --set STRING    Comma-separated setting names to turn ON
  --unset STRING    Comma-separated setting names to turn OFF

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  report: { asiakasId, roolit:{…}, settings:{ HAS_FENNOA:bool, ALV:bool, … every setting } } | write: { asiakasId, applied:{set,unset,dryRun}, state }

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Unknown setting name, or name in both --set/--unset → use a canonical ASIAKAS_SETTING_TYPE_IDS name, an alias, or pumppu
  exit 3 (HTTP 403)  Not an admin of this tenant → use a system-admin token, or an admin of the owner company
  exit 5 (HTTP 404)  Customer not found     → verify asiakasId
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib customer settings 1349
  ib customer settings --asiakas 1349 --set HAS_FENNOA,ALV --unset HAS_OCR --reason 'billing setup'
"
`;

exports[`Help snapshots — contract stability > help for ib customer update matches snapshot 1`] = `
"USAGE
  ib customer update <asiakasId> [flags]

DESCRIPTION
  Update a customer via read-merge-write: reads the current record, overlays the provided flags (preserving everything else — no contact-person clobber), writes back with saveGlobalAsiakas. --from-prh refreshes name+yTunnus+billing address from the registry (explicit flags still win). Billing postal address (--address/--postal-code/--city) is writable; pass an empty string to clear a field. --body raw JSON overrides flags.
  Permissions: requires auth.page.asiakas.edit.

ARGUMENTS
  <asiakasId> NUMBER    asiakasId to update (required)

FLAGS
  --name STRING    Customer name (asiakasNimi)
  --ytunnus STRING    Business ID (ytunnus)
  --email STRING    Invoicing email (laskutusEmail)
  --short-name STRING    Short display name (asiakasShortNimi)
  --comment STRING    Comment (kommentti)
  --contact-person NUMBER    Single PRIMARY contact personId (asiakasContactPersonId) — for memberships use \`customer person add\` (see docs: asiakas-contact-person-model)
  --type NUMBER    Customer type id (asiakasTypeId)
  --address STRING    Billing street address (laskutusOsoite)
  --postal-code STRING    Billing postal code (laskutusPostinumero)
  --city STRING    Billing city (laskutusKaupunki)
  --from-prh STRING    Refresh name + yTunnus + billing address from PRH (explicit flags still win)
  --body JSON    Raw JSON body (overrides typed flags)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  flat customer shape + changed:boolean|null (whether anything actually changed vs an idempotent no-op; null = undetermined) · wouldUpdate on --dry-run

ERRORS (stderr, exit non-zero)
  exit 5 (HTTP 404)  Customer not found     → verify asiakasId
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.asiakas.edit
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib customer update 26 --email new@x.fi --reason 'email change'
  ib customer update 26 --name 'Renamed Oy'
"
`;

