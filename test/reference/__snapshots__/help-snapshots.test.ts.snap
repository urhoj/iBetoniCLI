exports[`Help snapshots — contract stability > help for ib dev ai conversation matches snapshot 1`] = `
"USAGE
  ib dev ai conversation <conversationId> [flags]

DESCRIPTION
  Fetch the full transcript of an /ai assistant conversation by id (gptConversations/gptMessages). Developer/sysadmin tooling. The id originates from an \`ib feedback\` row's context.conversationId, stamped automatically when the AI files feedback from the /ai page.
  Permissions: requires isSystemAdmin or isDeveloper.

ARGUMENTS
  <conversationId> NUMBER    gptConversations id (from a feedback row's context.conversationId) (required)

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { conversationId, personId, ownerAsiakasId, messageCount, messages: [{ gptMessageId, role?, content?, raw?, ... }] }

ERRORS (stderr, exit non-zero)
  exit 4  Validation             → conversationId must be a positive integer
  exit 3 (HTTP 403)  Permission denied      → requires a developer token (isSystemAdmin/isDeveloper)
  exit 5 (HTTP 404)  Not found              → no conversation with that id
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Deploy-gated: 404 until puminet5api ships the /api/cli/ai/conversation/:id route.

SEE ALSO
  ib dev feedback get, ib dev feedback list

EXAMPLES
  ib dev ai conversation 4321
"
`;

exports[`Help snapshots — contract stability > help for ib dev ai conversations matches snapshot 1`] = `
"USAGE
  ib dev ai conversations [flags]

DESCRIPTION
  List recent /ai assistant conversations CROSS-TENANT for audit/browse (compact rows, newest-first, no message bodies). Developer/sysadmin tooling — the way to discover conversationIds to audit without an \`ib feedback\` row pointing at one. Drill into a transcript with \`ib dev ai conversation <id>\`.
  Permissions: requires isSystemAdmin or isDeveloper.

FLAGS
  --limit NUMBER    Max rows to return (1-100) (default: 20)
  --person NUMBER    Filter to one person's conversations (personId)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  ListEnvelope<{ conversationId, personId, ownerAsiakasId, entryTime, messageCount }> (truncated:true when the page hit --limit)

ERRORS (stderr, exit non-zero)
  exit 4  Validation             → --limit must be 1-100; --person must be a positive integer
  exit 3 (HTTP 403)  Permission denied      → requires a developer token (isSystemAdmin/isDeveloper)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Deploy-gated: 404 until puminet5api ships the /api/cli/ai/conversations route.

SEE ALSO
  ib dev ai conversation, ib dev feedback list

EXAMPLES
  ib dev ai conversations
  ib dev ai conversations --limit 50
  ib dev ai conversations --person 6233
"
`;

exports[`Help snapshots — contract stability > help for ib dev bug admin assign matches snapshot 1`] = `
"USAGE
  ib dev bug admin assign <bugReportId> [flags]

DESCRIPTION
  Assign a bug report to a developer; the backend also flips its status to in-progress. Developer-only. A real write — blocked under --read-only. --dry-run previews client-side.
  Permissions: requires isSystemAdmin or isDeveloper.

ARGUMENTS
  <bugReportId> NUMBER    bugReportId (required)

FLAGS
  --to NUMBER    Assignee personId (required)
  --reason STRING    Audit-log reason (X-Action-Reason)
  --dry-run BOOLEAN    Preview without sending (client-side)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  The updated report (status now in-progress). With --dry-run: { dryRun:true, wouldSend:{ method, path, body } }.

ERRORS (stderr, exit non-zero)
  exit 4  Validation             → --to <personId> must be a positive integer
  exit 3 (HTTP 403)  Permission denied      → requires a developer token; also refused under --read-only
  exit 5 (HTTP 404)  Not found              → check the id via \`ib dev bug list\`
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib dev bug admin assign 51 --to 6233
"
`;

exports[`Help snapshots — contract stability > help for ib dev bug admin delete matches snapshot 1`] = `
"USAGE
  ib dev bug admin delete <bugReportId> [flags]

DESCRIPTION
  Permanently delete a bug report. Developer-only and IRREVERSIBLE. A real write — blocked under --read-only. --reason is REQUIRED. --dry-run previews client-side.
  Permissions: requires isSystemAdmin or isDeveloper.

ARGUMENTS
  <bugReportId> NUMBER    bugReportId (required)

FLAGS
  --reason STRING    Audit-log reason (X-Action-Reason); REQUIRED (required)
  --dry-run BOOLEAN    Preview without sending (client-side)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { success: true, bugReportId } on success. With --dry-run: { dryRun:true, wouldSend:{ method, path, headers } }.

ERRORS (stderr, exit non-zero)
  exit 4  Validation             → --reason is required for delete
  exit 3 (HTTP 403)  Permission denied      → requires a developer token; also refused under --read-only
  exit 5 (HTTP 404)  Not found              → check the id via \`ib dev bug list\`
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib dev bug admin delete 51 --reason "duplicate of BR-40"
"
`;

