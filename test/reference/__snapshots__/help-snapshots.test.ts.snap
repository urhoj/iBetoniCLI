exports[`Help snapshots — contract stability > help for ib sijainti distance matches snapshot 1`] = `
"USAGE
  ib sijainti distance [flags]

DESCRIPTION
  Driving distance and time between two points (Google Maps). Each endpoint is either 'lat,lng' or a sijaintiId (resolved to its coordinates). ownerAsiakasId is derived from the active company.
  Permissions: requires auth.page.sijainnit.read.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --from STRING    Origin: 'lat,lng' or a sijaintiId (REQUIRED)
  --to STRING    Destination: 'lat,lng' or a sijaintiId (REQUIRED)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json

OUTPUT (JSON, stdout)
  { matkaM: number|null, matkaMin: number|null, from:{lat,lng}, to:{lat,lng} }

ERRORS (stderr, exit non-zero)
  400  Bad point or sijainti without coordinates → use 'lat,lng' or a sijaintiId that has coords
  401  Token expired          → ib auth refresh
  403  Permission denied      → check auth.page.sijainnit.read
  500  Backend error          → retry with --verbose

EXAMPLES
