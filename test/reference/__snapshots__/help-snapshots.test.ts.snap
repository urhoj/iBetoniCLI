exports[`Help snapshots — contract stability > help for ib bug create matches snapshot 1`] = `
"USAGE
  ib bug create [flags]

DESCRIPTION
  File a bug report into the betoni.online bugReport system. This is a LOUD write (distinct from the quiet \`ib feedback\`): it opens a GitHub issue AND emails admins. A real mutation — blocked under --read-only/IB_READ_ONLY (exit 3). CLI-filed reports are auto-tagged via browserInfo=ib-cli/<version>. --dry-run resolves client-side (prints the payload, never sends).
  Auth: requires login (any authenticated user).

FLAGS
  --type STRING    ui-display-issue | functionality-error | performance-problem | data-incorrect | other (required)
  --severity STRING    critical | major | minor | cosmetic (required)
  --description STRING    What is wrong (required)
  --steps STRING    Steps to reproduce
  --priority STRING    low | medium | high | urgent (omitted → derived from severity)
  --reason STRING    Audit reason (X-Action-Reason header)
  --dry-run BOOLEAN    Preview the payload without sending (client-side)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { bugReportId, referenceNumber } (HTTP 201). With --dry-run: { dryRun:true, wouldSend:{ method, path, body } }.

ERRORS (stderr, exit non-zero)
  exit 4  Validation             → --type/--severity/--description required; --type, --severity, --priority must be valid enum values
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Blocked under --read-only → this is a real write; drop --read-only / unset IB_READ_ONLY
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

SEE ALSO
  ib bug list, ib feedback create, ib attachment upload --bug-report <id>

EXAMPLES
  ib bug create --type functionality-error --severity major --description "Grid crashes on save" --steps "open grid, click save"
  ib bug create --type other --severity minor --description "preview" --dry-run
"
`;

