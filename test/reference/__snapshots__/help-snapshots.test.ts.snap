exports[`Help snapshots — contract stability > help for ib feedback list matches snapshot 1`] = `
"USAGE
  ib feedback list [flags]

DESCRIPTION
  List filed feedback for triage. Developer-only (isSystemAdmin / isDeveloper). Newest first, paginated (default 50, cap 200).
  Permissions: requires isSystemAdmin or isDeveloper.

FLAGS
  --status STRING    open | reviewed | applied | dismissed, or a comma-separated list (e.g. open,reviewed)
  --unresolved BOOLEAN    Shortcut for --status open,reviewed (un-closed items); mutually exclusive with --status
  --kind STRING    improvement | bug | idea | legal
  --scope STRING    cli | app | jerry | bsg2 | workspace | other
  --limit NUMBER    Max rows (cap 200) (default: 50)
  --offset NUMBER    Pagination offset (default: 0)
  --full BOOLEAN    Return untruncated description/resolution (default: each capped at 200 chars)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { items: FeedbackRow[] (description/resolution/errorText capped at 200 chars unless --full), nextCursor: null, count, truncated?, hint? }

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Permission denied      → requires a developer token (isSystemAdmin/isDeveloper)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib feedback list --status open --scope cli
  ib feedback list --unresolved
  ib feedback list --kind bug --limit 20
"
`;

exports[`Help snapshots — contract stability > help for ib feedback resolve matches snapshot 1`] = `
"USAGE
  ib feedback resolve <id> [flags]

DESCRIPTION
  Triage a feedback row: set its status and/or attach a resolution note (developer-only). This IS a real write — blocked under --read-only (exit 3). --dry-run previews the update body client-side without sending.
  Permissions: requires isSystemAdmin or isDeveloper.

ARGUMENTS
  <id> NUMBER    feedbackId (required)

FLAGS
  --status STRING    open | reviewed | applied | dismissed
  --note STRING    Resolution note stored on the row
  --dry-run BOOLEAN    Print the update body without sending (client-side)
  --full BOOLEAN    Return the full updated row instead of the compact ack

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  A compact ack { feedbackId, status, updatedAt, resolution } (resolution capped at 200 chars; the full row with --full). With --dry-run: { dryRun:true, wouldSend:{ method, path, body } }.

ERRORS (stderr, exit non-zero)
  exit 4  Validation             → provide --status and/or --note; status must be a known value
  exit 3 (HTTP 403)  Permission denied      → requires a developer token; also refused under --read-only
  exit 5 (HTTP 404)  Not found              → check the id via \`ib feedback list\`
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib feedback resolve 42 --status applied --note "added row counts in CLI v1.3"
  ib feedback resolve 42 --status dismissed --note "by design"
"
`;

