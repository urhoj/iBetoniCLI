exports[`Help snapshots — contract stability > help for ib reference dump matches snapshot 1`] = `
"USAGE
  ib reference dump [<domain>] [flags]

DESCRIPTION
  Emit the full command surface as JSON (version, generatedAt, overview, glossary, topics, feedbackGuidance, commands map). Read by AI assistants for one-shot CLI ingestion. Pass a domain (the token after \`ib\`, e.g. keikka) to narrow the commands map to one group — the primer (overview/glossary/topics) is always retained, so a filtered dump stays self-contained.
  Auth: none (public).

ARGUMENTS
  <domain> STRING    Restrict the commands map to one domain (the token after \`ib\`, e.g. keikka). Unknown domain exits 4 listing valid domains. (optional)

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  { version, generatedAt, overview, glossary, topics, feedbackGuidance, commands: { '<command>': CommandSpec } }

ERRORS (stderr, exit non-zero)
  exit 4  Unknown domain         → run \`ib commands\` to see valid domains
  exit 1  I/O error              → retry; check stdout pipe

EXAMPLES
  ib reference dump
  ib reference dump keikka
  ib reference dump | jq .version
"
`;

exports[`Help snapshots — contract stability > help for ib role explain matches snapshot 1`] = `
"USAGE
  ib role explain <name> [flags]

DESCRIPTION
  Explain a role NAME: its asiakasPersonSettingTypeId, human display name, the access tiers it grants (anyAdmin/anyWorker/anyViewer/laskuRead/requestOffer/adminCompanySelection), and whether it is deprecated — all from @ibetoni/constants. Enriched with the LIVE DB \`description\` (internal flag name, e.g. isAsiakasAdmin) and \`comment\` (rich Finnish text) read from GET /api/asiakasPersonSettings/getAllTypes, so the prose never drifts from dbo.asiakasPersonSettingTypes. Requires auth (any logged-in user); description/comment are null for roles the endpoint omits (soft-deleted pumppuHandler/Viewer). Use it to disambiguate the role names accepted by \`person role grant/revoke\` and \`customer person list --role\`.
  Auth: requires login (any authenticated user).

ARGUMENTS
  <name> STRING    role name (e.g. asiakasAdmin, keikkaHandler, lomaseurannassa) (required)

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  { role, typeId, displayName: string|null, description: string|null, comment: string|null, tiers: string[], deprecated: boolean }

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Unknown role name      → see ROLE_TYPEID_BY_NAME in @ibetoni/constants
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

SEE ALSO
  ib person role grant, ib person role revoke, ib customer person list

EXAMPLES
  ib role explain asiakasAdmin
  ib role explain lomaseurannassa
"
`;

