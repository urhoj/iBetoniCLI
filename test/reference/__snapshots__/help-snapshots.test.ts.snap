exports[`Help snapshots — contract stability > help for ib vehicle update matches snapshot 1`] = `
"USAGE
  ib vehicle update <vehicleId> [flags]

DESCRIPTION
  Update a vehicle (read-merge-write: only provided flags change; others preserved). POST /api/vehicle/save.
  Permissions: requires auth.page.vehicle.edit.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

ARGUMENTS
  <vehicleId> NUMBER    vehicleId to update (required)

FLAGS
  --reg STRING    Registration number
  --name STRING    Display name
  --no NUMBER    Fleet number
  --type NUMBER    vehicleTypeId
  --memo STRING    Free-text memo
  --default-driver NUMBER    Default driver personId
  --capacity NUMBER    Concrete capacity in m3
  --asiakas NUMBER    Owning asiakasId
  --show-in-grid BOOLEAN    Whether the vehicle appears in the grid (true/false)
  --first-date DATE    Start of validity window (firstDate); YYYY-MM-DD or today/yesterday/tomorrow
  --last-date DATE    End of validity window (lastDate); YYYY-MM-DD or today/yesterday/tomorrow

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  On write: the saved vehicle record. With --dry-run: { dryRun: true, vehicleId, wouldChange: { field: { from, to } } } — the field-level diff, computed client-side without POSTing (the save route ignores X-Dry-Run, so the preview cannot persist).

ERRORS (stderr, exit non-zero)
  exit 5 (HTTP 404)  Vehicle not found      → verify vehicleId
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.vehicle.edit
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib vehicle update 70 --capacity 8 --reason 'remeasured'
  ib vehicle update 70 --show-in-grid false --dry-run
  ib vehicle update 70 --last-date 2026-12-31 --reason 'retiring'
"
`;

exports[`Help snapshots — contract stability > help for ib vehicle visits matches snapshot 1`] = `
"USAGE
  ib vehicle visits <filterType> <id> [flags]

DESCRIPTION
  The active company's own vehicles that visited a worksite (tyomaa) or location (sijainti), grouped into visits with arrival/departure/duration (snapshot-based). Results are filtered to the caller's own fleet — other tenants' vehicles at a shared sijainti are not returned; a tyomaa must belong to the active company (else 404).
  Permissions: requires auth.page.vehicle.read.

ARGUMENTS
  <filterType> STRING    'tyomaa' or 'sijainti' (required)
  <id> NUMBER    tyomaaId or sijaintiId (required)

FLAGS
  --days NUMBER    Look-back window in days (omit for all-time)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  ListEnvelope<{ vehicleId, plate, objectName, arrived, departed, durationMin }> & { gpsAvailable }

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Invalid filterType     → use tyomaa or sijainti
  exit 5 (HTTP 404)  tyomaa not found / not owned → verify tyomaaId belongs to the active company
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.vehicle.read
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib vehicle visits tyomaa 17 --days 30
  ib vehicle visits sijainti 3
"
`;

exports[`Help snapshots — contract stability > help for ib version matches snapshot 1`] = `
"USAGE
  ib version [flags]

DESCRIPTION
  Show the local CLI version AND the deployed iB version at the active endpoint (server commit SHA + slot). Unauthenticated — works logged out, against any --endpoint. The whole deployable iB surface (the /api/cli routes + the vendored CLI) ships inside puminet5api, so the server \`commit\` is the single source of truth for which build is live; it changes on every deployed commit, letting you tell staging from prod without manual version bumps.
  Auth: none (public).

FLAGS
  --endpoint URL    Which deployment to query (global flag) (default: active profile, else https://api.ibetoni.fi)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  { cli, endpoint, reachable, server: { app, version, commit, release, slot } | null, error? }

ERRORS (stderr, exit non-zero)
  exit 7  Endpoint unreachable   → check --endpoint / network; the report (cli version + error) still prints

EXAMPLES
  ib version
  ib version --endpoint https://api.ibetoni.fi
  ib version --endpoint https://api-staging.ibetoni.fi
"
`;

exports[`Help snapshots — contract stability > help for ib weather address matches snapshot 1`] = `
"USAGE
  ib weather address [flags]

DESCRIPTION
  Point forecast for a street address: geocodes the address via Google Maps (POST /api/geocode/getLatLng), then calls FMI for the forecast. Requires the company weather module. Fails with exit 5 (not-found) if the address returns ZERO_RESULTS from Google.
  Permissions: requires company weather module (asiakasPersonSettingTypeId 18).

FLAGS
  --address STRING    Street address (min 5 chars)
  --time STRING    Forecast time (ISO 8601 or 'now')

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  { temperature, windSpeed, precipitation, cloudCover, weatherSymbol, description, source, coordinates, forecastTime, cached? }

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Weather module off or permission denied → enable via 'ib weather toggle --on'
  exit 5  Address not found (ZERO_RESULTS) → try a more specific Finnish address
  exit 2 (HTTP 401)  Not authenticated      → run 'ib auth login'
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib weather address --address 'Mannerheimintie 1, Helsinki' --time now
  ib weather address --address 'Tampereen valtatie 5, Tampere' --time 2026-06-10T10:00:00Z
"
`;

exports[`Help snapshots — contract stability > help for ib weather day matches snapshot 1`] = `
"USAGE
  ib weather day [flags]

DESCRIPTION
  Daily aggregate weather forecast (min/max/avg temperature, wind, precipitation) for a lat/lng on a calendar date. Accepts relative date aliases: today, tomorrow, yesterday. Coordinates must be within Finland. Requires the company weather module.
  Permissions: requires company weather module (asiakasPersonSettingTypeId 18).

FLAGS
  --lat NUMBER    Latitude (Finland 59.5–70.1)
  --lng NUMBER    Longitude (Finland 19.0–31.6)
  --date STRING    Date (YYYY-MM-DD, or today/tomorrow/yesterday)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  { date, minTemp, maxTemp, avgTemp, windSpeed, precipitation, weatherSymbol, source, coordinates }

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Weather module off or permission denied → enable via 'ib weather toggle --on'
  exit 4 (HTTP 400)  Bad coords/date        → use Finland coords and a valid date
  exit 2 (HTTP 401)  Not authenticated      → run 'ib auth login'
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib weather day --lat 60.17 --lng 24.94 --date today
  ib weather day --lat 60.17 --lng 24.94 --date 2026-06-10
"
`;

exports[`Help snapshots — contract stability > help for ib weather forecast matches snapshot 1`] = `
"USAGE
  ib weather forecast [flags]

DESCRIPTION
  Single-point FMI weather forecast for a lat/lng at a given time. Coordinates must be within Finland (lat 59.5–70.1, lng 19.0–31.6). Time must be within now..+240h. Requires the company weather module (asiakasPersonSettingTypeId 18); 403 if disabled.
  Permissions: requires company weather module (asiakasPersonSettingTypeId 18).

FLAGS
  --lat NUMBER    Latitude (Finland 59.5–70.1)
  --lng NUMBER    Longitude (Finland 19.0–31.6)
  --time STRING    Forecast time, ISO 8601 or 'now'

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  { temperature, windSpeed, precipitation, cloudCover, weatherSymbol, description, source, coordinates, forecastTime, cached? }

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Weather module off or permission denied → enable via 'ib weather toggle --on' (admin) or contact an admin
  exit 4 (HTTP 400)  Bad coords/time        → use Finland coords and a time within now..+240h
  exit 2 (HTTP 401)  Not authenticated      → run 'ib auth login'
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib weather forecast --lat 60.1699 --lng 24.9384 --time now
  ib weather forecast --lat 60.1699 --lng 24.9384 --time 2026-06-09T14:00:00Z
"
`;

exports[`Help snapshots — contract stability > help for ib weather pumping matches snapshot 1`] = `
"USAGE
  ib weather pumping [flags]

DESCRIPTION
  Weather analysis over a concrete-pumping window: hourly conditions for the entire duration starting at --start. The backend can correlate with a keikka via --keikka for error reporting. Requires the company weather module.
  Permissions: requires company weather module (asiakasPersonSettingTypeId 18).

FLAGS
  --lat NUMBER    Latitude (Finland 59.5–70.1)
  --lng NUMBER    Longitude (Finland 19.0–31.6)
  --start STRING    Pumping start time (ISO 8601 or 'now')
  --duration NUMBER    Pumping duration in minutes
  --keikka NUMBER    Keikka id (optional, for backend error correlation only)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  { hourly: [{ time, temperature, windSpeed, precipitation, weatherSymbol }], summary, coordinates }

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Weather module off or permission denied → enable via 'ib weather toggle --on'
  exit 4 (HTTP 400)  Bad coords/time/duration → use Finland coords, valid ISO time, positive duration
  exit 2 (HTTP 401)  Not authenticated      → run 'ib auth login'
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib weather pumping --lat 60.17 --lng 24.94 --start now --duration 120
  ib weather pumping --lat 60.17 --lng 24.94 --start 2026-06-10T08:00:00Z --duration 90 --keikka 1234
"
`;

exports[`Help snapshots — contract stability > help for ib weather status matches snapshot 1`] = `
"USAGE
  ib weather status [flags]

DESCRIPTION
  Check whether the weather module is enabled for the active company. Does not require the weather module itself to be enabled (no circular dependency). Returns the enabled/disabled status and related settings.
  Auth: requires login (any authenticated user).

FLAGS
  (none)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  { enabled: boolean, ... }

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Not authenticated      → run 'ib auth login'
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib weather status
"
`;

exports[`Help snapshots — contract stability > help for ib weather toggle matches snapshot 1`] = `
"USAGE
  ib weather toggle [flags]

DESCRIPTION
  Enable or disable the weather module for the active company. Pass exactly one of --on or --off. Admin-scoped operation. Supports --dry-run, --idempotency-key, and --reason for audit trail.
  Auth: requires login (any authenticated user).

FLAGS
  --on BOOLEAN    Enable the module
  --off BOOLEAN    Disable the module

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  { success: boolean, enabled: boolean, ... }

ERRORS (stderr, exit non-zero)
  exit 4  Neither --on nor --off passed, or both passed → pass exactly one of --on / --off
  exit 3 (HTTP 403)  Permission denied (admin required) → requires admin role on the company
  exit 2 (HTTP 401)  Not authenticated      → run 'ib auth login'
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib weather toggle --on --reason 'enabling for summer season'
  ib weather toggle --off --dry-run
"
`;

exports[`Help snapshots — contract stability > help for ib weather worksite matches snapshot 1`] = `
"USAGE
  ib weather worksite <tyomaaId> [flags]

DESCRIPTION
  Forecast for a worksite identified by tyomaaId. The backend resolves the coordinates from the tyomaa record internally — no lat/lng needed. Use --force-refresh to bypass the cache. Requires the company weather module.
  Permissions: requires company weather module (asiakasPersonSettingTypeId 18).

ARGUMENTS
  <tyomaaId> NUMBER    tyomaaId (coordinates resolved server-side) (required)

FLAGS
  --force-refresh BOOLEAN    Bypass the cache and refetch from FMI

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  { temperature, windSpeed, precipitation, cloudCover, weatherSymbol, description, source, coordinates, forecastTime, cached? }

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Weather module off or permission denied → enable via 'ib weather toggle --on'
  exit 5 (HTTP 404)  Tyomaa not found or has no coordinates → check tyomaaId; ensure the worksite has been geocoded
  exit 2 (HTTP 401)  Not authenticated      → run 'ib auth login'
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib weather worksite 1234
  ib weather worksite 1234 --force-refresh
"
`;

exports[`Help snapshots — contract stability > help for ib worksite create matches snapshot 1`] = `
"USAGE
  ib worksite create [flags]

DESCRIPTION
  Create a new worksite via POST /api/tyomaa/new. Body forwarded verbatim.
  Permissions: requires auth.page.tyomaa.edit.

FLAGS
