  --mine BOOLEAN    Customer counts (default)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  --mine: { draft, open, pending_verification, accepted, cancelled, expired, no_supply } | --provider: { avoimet, tarjotut, voitetut, voitetutActionRequired, paattyneet }

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Not a provider (for --provider) → switch to a provider company, or use --mine
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib jerry counts
  ib jerry counts --provider
"
`;

exports[`Help snapshots — contract stability > help for ib jerry offer accept matches snapshot 1`] = `
"USAGE
  ib jerry offer accept <requestId> <offerId> [flags]

DESCRIPTION
  Accept an offer (CUSTOMER side; POST /api/pumppuRequests/:id/offers/:offerId/accept). Flips this offer to 'accepted', sibling offers to 'rejected', and the parent request to 'accepted' in one transaction. Caller must own the request (its personId) — this is NOT a provider action. Requires --reason.
  Permissions: requires owns the request (customer personId).

ARGUMENTS
  <requestId> NUMBER    pumppuRequestId you own (required)
  <offerId> NUMBER    pumppuOfferId to accept (required)

FLAGS
  --reason STRING    Audit-log reason (X-Action-Reason); REQUIRED

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { pumppuRequestId, pumppuOfferId, keikkaId:null, status:'accepted' } · { dryRun:true, wouldAccept:{ pumppuRequestId, pumppuOfferId, status:'accepted' } } on --dry-run

ERRORS (stderr, exit non-zero)
  exit 5 (HTTP 404)  Request not found / not yours → verify requestId and that you own it
  exit 4 (HTTP 409)  Offer no longer acceptable → a sibling was already accepted, or the offer expired
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib jerry offer accept 4012 55 --reason "valittu toimittaja"
"
`;

exports[`Help snapshots — contract stability > help for ib jerry offer confirm matches snapshot 1`] = `
"USAGE
  ib jerry offer confirm <requestId> <offerId> [flags]

DESCRIPTION
  Confirm an accepted offer (PROVIDER side; POST /api/pumppuRequests/:id/offers/:offerId/confirm).
  Permissions: requires provider company (isPumppuToimittaja); owns the offer.

ARGUMENTS
  <requestId> NUMBER    pumppuRequestId (required)
  <offerId> NUMBER    pumppuOfferId you own (must be 'accepted') (required)

FLAGS
  --scheduled-at STRING    Scheduled keikka start (REQUIRED; future ISO datetime)
  --pumppu NUMBER    vehicleId to pin to the keikka (must be yours)
  --reason STRING    Audit-log reason (X-Action-Reason); REQUIRED

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { pumppuRequestId, pumppuOfferId, status:'confirmed', keikkaId, scheduledAt } · { dryRun:true, wouldConfirm:{ pumppuRequestId, pumppuOfferId, status:'confirmed', scheduledAt, pumppuId } } on --dry-run

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  scheduledAt missing/invalid/in the past, or pumppuId not yours → pass --scheduled-at as a future ISO datetime; --pumppu must be your vehicleId
  exit 3 (HTTP 403)  Not a provider / offer not yours → switch to the owning provider company
  exit 5 (HTTP 404)  Request / offer not found → verify requestId + offerId
  exit 4 (HTTP 409)  Offer not in 'accepted' state → the customer must accept the offer before you confirm
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Heavyweight, real side effects: flips the offer accepted → 'confirmed' AND builds a keikka in your grid (broadcasts keikka:created, notifies the customer, inherits the vehicle's day driver).
  - Call only after the customer accepts and you've agreed a date by phone.
  - --scheduled-at (future ISO datetime) is required.
  - --pumppu optionally pins one of your vehicles.

SEE ALSO
  ib jerry offer accept, ib jerry request get

EXAMPLES
  ib jerry offer confirm 4012 55 --scheduled-at 2026-06-15T08:00:00Z --reason vahvistettu
  ib jerry offer confirm 4012 55 --scheduled-at 2026-06-15T08:00:00Z --pumppu 7 --dry-run --reason preview
"
`;

exports[`Help snapshots — contract stability > help for ib jerry offer create matches snapshot 1`] = `
"USAGE
  ib jerry offer create <requestId> [flags]

DESCRIPTION
  Create or update (upsert) YOUR offer on a request (POST /api/pumppuRequests/:id/offers). Provider company only (isPumppuToimittaja). A new offer starts as 'draft' (invisible to the customer) — make it visible with \`ib jerry offer send\`. Re-running while the offer is still draft/pending edits it in place; once accepted/rejected/withdrawn it is final (409). --price-cents is the canonical price (integer cents, 1..99999900) matching exactly what the API stores; --maintains-order-info (true|false) overrides the provider default for this offer only (omit to inherit). Requires --reason.
  Permissions: requires provider company (isPumppuToimittaja).

ARGUMENTS
  <requestId> NUMBER    pumppuRequestId (required)

FLAGS
  --price-cents NUMBER    Offer price in cents (REQUIRED; integer 1..99999900)
  --vat-percent NUMBER    VAT percent (default: 25.5)
  --price-terms STRING    Price-estimate terms (Hinta-arvion ehdot) shown to the customer
  --valid-until STRING    Offer valid-until (ISO datetime; server default +7d)
  --available-from STRING    Earliest availability (ISO datetime; stored, not shown on the BetoniJerry customer card)
  --extra-notes STRING    Free-text notes shown to the customer
  --cancellation-terms STRING    Per-offer cancellation terms (stored; BetoniJerry shows a platform-standard peruutusehdot, so this is NOT rendered on the customer card)
  --maintains-order-info STRING    Override provider default (true|false); omit to inherit
  --reason STRING    Audit-log reason (X-Action-Reason); REQUIRED

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { pumppuOfferId, status:'draft', created, messageThreadId } · { dryRun:true, wouldUpsert:{ pumppuRequestId, priceCents, vatPercent, priceTerms, validUntil, availableFrom, extraNotes, cancellationTerms, maintainsOrderInfo } } on --dry-run

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  priceCents missing / out of range → pass --price-cents as an integer 1..99999900
  exit 3 (HTTP 403)  Not a provider         → switch to a provider company (company switch)
  exit 5 (HTTP 404)  Request not found      → verify requestId
  exit 4 (HTTP 409)  Request not open / expired, or offer no longer editable → the request was closed, or your offer is already accepted/rejected
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib jerry offer create 4012 --price-cents 45000 --reason "tarjous"
  ib jerry offer create 4012 --price-cents 45000 --vat-percent 25.5 --maintains-order-info false --extra-notes "sis. siirtymat" --reason "tarjous"
  ib jerry offer create 4012 --price-cents 45000 --price-terms "Arvioitu hinta; laskutus toteutuneen mukaan" --reason "tarjous"
  ib jerry offer create 4012 --price-cents 45000 --dry-run --reason "preview"
"
`;

exports[`Help snapshots — contract stability > help for ib jerry offer delete matches snapshot 1`] = `
"USAGE
  ib jerry offer delete <requestId> <offerId> [flags]

DESCRIPTION
  Hard-delete YOUR OWN DRAFT offer (DELETE /:id/offers/:offerId). Provider-only; you must own the offer; DRAFT status ONLY — a sent offer (pending/accepted/…) returns 409, use \`ib jerry offer withdraw\` for a pending one. The offer's attachments are soft-deleted server-side; the (request, provider) message thread is left in place for reuse. Requires --reason.
  Permissions: requires isProvider.

ARGUMENTS
  <requestId> NUMBER    pumppuRequestId (required)
  <offerId> NUMBER    your DRAFT pumppuOfferId (required)

FLAGS
  --reason STRING    Audit-log reason (X-Action-Reason); REQUIRED

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { success: true, pumppuOfferId, deleted: true } or { dryRun: true, wouldDelete: { pumppuOfferId, status } }

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Not a provider         → use a pump-company token
  exit 5 (HTTP 404)  Offer not found / not yours → verify requestId + offerId
  exit 4 (HTTP 409)  Not a draft            → only a draft offer can be deleted; use withdraw for a sent offer
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib jerry offer delete 77 5 --reason "väärä luonnos"
"
`;

exports[`Help snapshots — contract stability > help for ib jerry offer send matches snapshot 1`] = `
"USAGE
  ib jerry offer send <requestId> <offerId> [flags]

DESCRIPTION
  Send a draft offer to the customer (draft → 'pending'; POST /api/pumppuRequests/:id/offers/:offerId/send). Provider company only; you must own the offer. Two-stage by design: create the draft, attach files, then send. Requires --reason.
  Permissions: requires provider company (isPumppuToimittaja); owns the offer.

ARGUMENTS
  <requestId> NUMBER    pumppuRequestId (required)
  <offerId> NUMBER    pumppuOfferId you own (required)

FLAGS
  --reason STRING    Audit-log reason (X-Action-Reason); REQUIRED

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { pumppuOfferId, status:'pending' } · { dryRun:true, wouldUpdate:{ pumppuRequestId, pumppuOfferId, status:'pending' } } on --dry-run

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Not a provider         → switch to a provider company (company switch)
  exit 4 (HTTP 409)  Offer not in draft / not owned → only a draft offer you own can be sent
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib jerry offer send 4012 55 --reason "lahetä tarjous"
  ib jerry offer send 4012 55 --dry-run --reason preview
"
`;

exports[`Help snapshots — contract stability > help for ib jerry offer withdraw matches snapshot 1`] = `
"USAGE
  ib jerry offer withdraw <requestId> <offerId> [flags]

DESCRIPTION
  Withdraw YOUR sent offer before the customer accepts it (POST /:id/offers/:offerId/withdraw). pending → withdrawn. Provider-only; you must own the offer. Requires --reason.
  Permissions: requires isProvider.

ARGUMENTS
  <requestId> NUMBER    pumppuRequestId (required)
  <offerId> NUMBER    your pumppuOfferId (required)

FLAGS
  --reason STRING    Audit-log reason (X-Action-Reason); REQUIRED

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { success: true, status: 'withdrawn' } or { dryRun: true, wouldUpdate: { pumppuOfferId, status } }

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Not a provider         → use a pump-company token
  exit 5 (HTTP 404)  Offer not found / not yours → verify requestId + offerId
  exit 4 (HTTP 409)  Already resolved       → cannot withdraw once accepted/confirmed
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib jerry offer withdraw 77 5 --reason "kalusto varattu"
"
`;

exports[`Help snapshots — contract stability > help for ib jerry provider-settings get matches snapshot 1`] = `
"USAGE
  ib jerry provider-settings get [flags]

DESCRIPTION
  Read a provider company's BetoniJerry settings — contact person, opening hours, company description, maintainsOrderInfo (GET /api/jerry-provider-settings). Defaults to the caller's own company; --asiakas targets another company you have edit rights on. Returns defaults when no row exists yet.
  Permissions: requires edit-tier on the target company (tarjousAdmin / company admin).

FLAGS
  --asiakas NUMBER    Target company asiakasId (default: your own)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { asiakasId, jerryPersonId, jerryPersonName, jerryPersonPhone, openingHours, companyDescription, maintainsOrderInfo }

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  No edit rights on company → use a tarjousAdmin/admin token for that company
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib jerry provider-settings get
  ib jerry provider-settings get --asiakas 1402
"
`;

exports[`Help snapshots — contract stability > help for ib jerry provider-settings set matches snapshot 1`] = `
"USAGE
  ib jerry provider-settings set [flags]

DESCRIPTION
  Upsert a provider company's BetoniJerry settings (PUT /api/jerry-provider-settings). Partial-payload-safe: only the body keys present are written (omit a key to preserve it). jerryPersonId must belong to the target company. --asiakas targets another company. Returns the FULL saved settings (no follow-up GET needed) plus changed:boolean (whether anything actually changed vs an idempotent no-op). companyDescription is nvarchar — ä/ö are preserved. Requires --reason.
  Permissions: requires edit-tier on the target company (tarjousAdmin / company admin).

FLAGS
  --body JSON    JSON: { jerryPersonId?, openingHours?, companyDescription?, maintainsOrderInfo? }
  --asiakas NUMBER    Target company asiakasId (default: your own)
  --reason STRING    Audit-log reason (X-Action-Reason); REQUIRED

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { asiakasId, jerryPersonId, jerryPersonName, jerryPersonPhone, openingHours, companyDescription, maintainsOrderInfo, changed } · { dryRun: true, wouldUpdate: {...} } on --dry-run

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Invalid field / contact not in company → check jerryPersonId belongs to the company
  exit 3 (HTTP 403)  No edit rights on company → use a tarjousAdmin/admin token for that company
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib jerry provider-settings set --body '{"openingHours":"ma-pe 7-16","maintainsOrderInfo":true}' --reason "update opening hours"
  ib jerry provider-settings set --body '{"jerryPersonId":6233}' --asiakas 1402 --reason "set contact"
"
`;

exports[`Help snapshots — contract stability > help for ib jerry request cancel matches snapshot 1`] = `
"USAGE
  ib jerry request cancel <requestId> [flags]

DESCRIPTION
  Cancel your OWN pump request (customer-side) — allowed only while no live offer exists (POST /api/pumppuRequests/:id/cancel). Sets status='cancelled'. Requires --reason.

ARGUMENTS
  <requestId> NUMBER    pumppuRequestId you own (required)

FLAGS
  --reason STRING    Audit-log reason (X-Action-Reason); REQUIRED

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { success: true, status: 'cancelled' } or { dryRun: true, wouldUpdate: { pumppuRequestId, status } }

ERRORS (stderr, exit non-zero)
  exit 5 (HTTP 404)  Request not found / not yours → verify the requestId and that you own it
  exit 4 (HTTP 409)  Already has offers     → cannot cancel once an offer arrived
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib jerry request cancel 88 --reason "tilaus peruuntui"
"
`;

exports[`Help snapshots — contract stability > help for ib jerry request create matches snapshot 1`] = `
"USAGE
  ib jerry request create <address> [flags]

DESCRIPTION
  Create a customer pump request / tarjouspyyntö (POST /api/pumppuRequests). Any authenticated user — this is the CUSTOMER side (distinct from \`ib jerry offer create\`, the provider bid). The worksite address is given positionally OR via --address (exactly one; both allowed only if they agree). The server geocodes the address and inserts the request as status:'open', immediately visible to every geographically-matching provider. Omit --asiakas to bill it to your auto-created private BetoniJerry customer account; pass --asiakas to use a company you have access to. Requires --reason. ⚠ --dry-run is honoured only once the backend change deploys — against older backends X-Dry-Run is ignored and the request IS created.
  Auth: requires login (any authenticated user).

ARGUMENTS
  <address> STRING    Worksite address (osoite); positional, or use --address (required)

FLAGS
  --address STRING    Worksite address (osoite); alias for the positional
  --pump-at STRING    Pump datetime (pumppausaika; ISO, REQUIRED), e.g. 2026-06-17T09:00:00+03:00
  --m3 NUMBER    Concrete volume m³ (maaraM3; REQUIRED, > 0)
  --boom NUMBER    Required boom reach m (puomi) (default: 0)
  --duration NUMBER    Pump duration hours (kesto)
  --line-length NUMBER    Hose line length m (linjanPituus)
  --notes STRING    Free-text description shown to providers (kuvaus)
  --asiakas NUMBER    Customer asiakasId (omit → your private BetoniJerry account)
  --reason STRING    Audit-log reason (X-Action-Reason); REQUIRED

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { pumppuRequestId, status:'open', asiakasId, personId, tyomaaId, geocoded } · { dryRun:true, wouldCreate:{ asiakasId, osoite, pumppuAika, totalM3, requiredPuomi, pumppuKesto, requiredLinja, notes }, validation:{ ok:true } } on --dry-run

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  osoite/pumppausaika/maaraM3 missing or invalid → pass the address (positional or --address), --pump-at (ISO), --m3 (> 0)
  exit 3 (HTTP 403)  No access to --asiakas → omit --asiakas, or target a company you belong to
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Customer side: creates the tarjouspyyntö itself, NOT a provider offer (that is \`ib jerry offer create\`).
  - Created as status:'open' → immediately fans out to matching provider inboxes. Run \`ib jerry check-address\` first to preview which providers (if any) cover the address.
  - --dry-run is deploy-gated: until the backend honouring X-Dry-Run deploys, --dry-run still creates the request.

SEE ALSO
  ib jerry check-address, ib jerry request list, ib jerry offer create

EXAMPLES
  ib jerry request create "Mannerheimintie 1, Helsinki" --pump-at 2026-06-17T09:00:00+03:00 --m3 30 --reason "tilaus"
  ib jerry request create --address "Mannerheimintie 1, Helsinki" --pump-at 2026-06-17T09:00:00+03:00 --m3 30 --boom 24 --notes "ahdas piha" --reason "tilaus"
  ib jerry request create "Mannerheimintie 1, Helsinki" --pump-at 2026-06-17T09:00:00+03:00 --m3 30 --dry-run --reason "preview"
"
`;

exports[`Help snapshots — contract stability > help for ib jerry request get matches snapshot 1`] = `
"USAGE
  ib jerry request get <requestId> [flags]

DESCRIPTION
  Get one pump request. Default is the customer-owned recap (GET /api/pumppuRequests/:id, scoped to the caller's personId). --provider returns the provider-facing detail (GET /api/pumppuRequests/:id/provider-detail, requires provider role) including your own offer + attachments; customer PII (lat/lng/phone/email) stays masked until your offer is accepted/confirmed.
  Permissions: requires --provider: provider company (isPumppuToimittaja).

ARGUMENTS
  <requestId> NUMBER    pumppuRequestId (required)

FLAGS
  --provider BOOLEAN    Provider-facing detail view (provider role)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  default: { pumppuRequestId, status, asiakasId, maaraM3, osoite, lat, lng, ... } | --provider: { request:{...}, ownOffer:{...}|null, ownAttachments:[…], requestAttachments:[…], messageThreadId }

ERRORS (stderr, exit non-zero)
  exit 5 (HTTP 404)  Request not found / not yours → verify requestId (and that you own it, or use --provider)
  exit 3 (HTTP 403)  Not a provider (for --provider) → switch to a provider company
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib jerry request get 4012
  ib jerry request get 4012 --provider
"
`;

exports[`Help snapshots — contract stability > help for ib jerry request list matches snapshot 1`] = `
"USAGE
  ib jerry request list [flags]

DESCRIPTION
  List BetoniJerry pump requests (tarjouspyynnöt). Default --mine returns the caller's own requests (GET /api/pumppuRequests/mine). --open returns the provider inbox of open requests in your delivery area (GET /api/pumppuRequests/open) and requires a provider company (isPumppuToimittaja); customer PII is masked there until your offer is accepted. --status (CSV) and --limit apply to --mine only. (Whole-market visibility is system-admin only — see \`ib jerry admin requests\`.)
  Permissions: requires --open: provider company (isPumppuToimittaja).

FLAGS
  --open BOOLEAN    Provider inbox of open requests in your delivery area (provider role)
  --mine BOOLEAN    Your own requests (default)
  --status STRING    Filter --mine by status (CSV: open,pending_verification,accepted,cancelled,expired,no_supply)
  --limit NUMBER    Max rows for --mine (server caps at 200) (default: 100)
  --provider BOOLEAN    Provider lifecycle view via /provider-list (incl. sent offers)
  --tab STRING    With --provider: avoimet|tarjotut|voitetut|paattyneet

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  ListEnvelope<{ pumppuRequestId, status, createdAt, sentAt?, osoite, formattedAddress, totalM3|maaraM3, ... }> (fields differ between --mine and --open; --open is PII-masked)

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Not a provider (for --open) → switch to a provider company, or use --mine
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib jerry request list
  ib jerry request list --open
  ib jerry request list --mine --status open,accepted --limit 50
  ib jerry request list --provider --tab tarjotut
"
`;

