exports[`Help snapshots — contract stability > help for ib company switch matches snapshot 1`] = `
"USAGE
  ib company switch [flags]

DESCRIPTION
  Switch the active company. Alias of \`ib auth switch\`. Persists the rotated JWT.
  Auth: requires login (any authenticated user).

FLAGS
  --to NUMBER    Target asiakasId to switch to

GLOBAL FLAGS
