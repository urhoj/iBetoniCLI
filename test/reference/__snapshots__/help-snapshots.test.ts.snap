exports[`Help snapshots — contract stability > help for ib customer prh matches snapshot 1`] = `
"USAGE
  ib customer prh [flags]

DESCRIPTION
  Look up a company in the Finnish business registry (PRH). Positional <ytunnus> for an exact business-ID lookup, or --search <name>. Read-only; any authenticated user.
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --ytunnus STRING    Positional — business ID (XXXXXXXX-X)
  --search STRING    Search by company name instead
  --page NUMBER    Result page for --search (default: 1)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json

OUTPUT (JSON, stdout)
  by-id: { businessId, name, tradeNames, address:{street,postCode,city,full}, companyForm, status } | search: ListEnvelope<{ businessId, name, city }>

ERRORS (stderr, exit non-zero)
  404  Business ID not found  → verify the Y-tunnus
  400  Invalid Y-tunnus format → use XXXXXXXX-X
  401  Token expired          → ib auth refresh
  500  Backend error          → retry with --verbose

EXAMPLES
  ib customer prh 0145937-9
  ib customer prh --search Betoni
"
`;

