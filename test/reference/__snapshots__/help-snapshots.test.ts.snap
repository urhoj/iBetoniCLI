exports[`Help snapshots — contract stability > help for ib cache pattern matches snapshot 1`] = `
"USAGE
  ib cache pattern <glob> [flags]

DESCRIPTION
  Invalidate keys matching a raw Redis glob. Previews unless --confirm. Guard: refuses deployed endpoints unless --force-prod. Developer-only. Prefer \`ib cache invalidate\` (domain entity); use \`ib cache keys\` to find the right glob.
  Permissions: requires isSystemAdmin or isDeveloper.

ARGUMENTS
  <glob> STRING    Raw Redis key glob (e.g. 'keikka:*') (required)

FLAGS
  --confirm BOOLEAN    Execute the operation (default is dry-run preview)
  --force-prod BOOLEAN    Allow execution against a deployed (shared-cache) endpoint
  --reason STRING    Audit reason (X-Action-Reason)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --asiakas ID

OUTPUT (JSON, stdout)
  preview: { dryRun:true, wouldDelete, pattern } | execute: { deleted, pattern }

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Not a developer        → requires isSystemAdmin or isDeveloper
  exit 6 (HTTP 500)  Backend error          → retry with --verbose
  exit 3  Refused: deployed endpoint without --force-prod → prod and staging share Redis DB 3; add --force-prod or use a local endpoint
  exit 3  Blocked by read-only mode → executing a cache write needs --confirm and a session without --read-only/IB_READ_ONLY (previews still work)

EXAMPLES
  ib cache pattern 'keikka:*'
  ib cache pattern 'person:*' --confirm --force-prod
"
`;

