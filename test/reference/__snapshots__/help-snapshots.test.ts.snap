exports[`Help snapshots — contract stability > help for ib person create matches snapshot 1`] = `
"USAGE
  ib person create [flags]

DESCRIPTION
  Create a person. REQUIRED: --first, --last. --email is OPTIONAL (personEmail is nullable; phone-only contacts are fine and the email can be added later via \`ib person update\`). --asiakas defaults to your active company. Returns the created person record (clean {personId, ...}), NOT the raw SQL recordset. With --get-or-create a duplicate email returns the existing person (reused:true) instead of failing — useful for idempotent bulk onboarding. Use typed flags or --body JSON (typed flags win). Requires --reason. Use --global to create a GLOBAL, self-managing person (ownerAsiakasId=null) discoverable across companies; --global and --asiakas are mutually exclusive.
  Permissions: requires auth.page.person.edit.

FLAGS
  --first STRING    personFirstName (REQUIRED)
  --last STRING    personLastName (REQUIRED)
  --phone STRING    personPhone
  --email STRING    personEmail (optional)
  --asiakas NUMBER    Owner asiakasId (defaults to your active company)
  --global BOOLEAN    Create a global, owner-less person (ownerAsiakasId=null). Mutually exclusive with --asiakas.
  --get-or-create BOOLEAN    On a duplicate email, return the existing person (reused:true) instead of failing
  --body JSON    Raw JSON body, merged under typed flags (optional)
  --reason STRING    Audit-log reason (REQUIRED)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { personId, name, email, ... } (re-fetched) · with --get-or-create adds reused:boolean · dry-run: { dryRun: true, wouldCreate: ... }

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Missing required field, or duplicate email without --get-or-create → provide --first and --last (email is optional); add --get-or-create to reuse an existing email
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 3 (HTTP 403)  Permission denied      → check auth.page.person.edit
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib person create --first Matti --last Virtanen --phone "+358501234567" --reason "phone contact"
  ib person create --first Matti --last Virtanen --email m@x.com --get-or-create --reason "onboard"
  ib person create --body '{"personFirstName":"Matti","personLastName":"M"}' --reason "onboard"
  ib person create --first Matti --last Virtanen --global --reason "global self-managing person"
"
`;

exports[`Help snapshots — contract stability > help for ib person day clear matches snapshot 1`] = `
"USAGE
  ib person day clear [flags]

DESCRIPTION
  Delete a person's day row for a date (remove status entry). Requires --reason.
  Auth: requires login (any authenticated user).
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --person NUMBER    personId (required)
  --date DATE    Day YYYY-MM-DD (or today/yesterday/tomorrow) (required)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  delete result | { dryRun:true, wouldDelete:{ personPvmId, date, status } | null } (with --dry-run)

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Missing --reason       → supply --reason
  exit 3 (HTTP 403)  Requires Admin or HR Admin on the active company → use an Admin/HR account
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Requires Admin or HR Admin (server-enforced).
  - --reason is hard-required (exits 4 without it).
  - --dry-run is CLIENT-side: previews wouldDelete and never deletes.
  - Resolves the personPvmId via the day list; when no row exists it's a no-op (deleted:false).

SEE ALSO
  ib person day set, ib person day get

EXAMPLES
  ib person day clear --person 555 --date 2026-06-10 --reason 'loma peruttu'
"
`;

exports[`Help snapshots — contract stability > help for ib person day get matches snapshot 1`] = `
"USAGE
  ib person day get [flags]

DESCRIPTION
  List a person's day rows (status / vehicle / text) over a date range
  Auth: requires login (any authenticated user).
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --person NUMBER    personId (required)
  --from DATE    Start date YYYY-MM-DD (or today/yesterday/tomorrow) (required)
  --to DATE    End date YYYY-MM-DD (default: --from)

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  ListEnvelope<{ personPvmId, date, statusId, status, pois, vehicleId, text }>

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Scoped to the active company (same-tenant).
  - \`status\` is the personPvmStatus code; map statusId→friendly name via \`ib person day statuses\`.

SEE ALSO
  ib person day set, ib driver who

EXAMPLES
  ib person day get --person 555 --from today
  ib person day get --person 555 --from 2026-06-01 --to 2026-06-30
"
`;

exports[`Help snapshots — contract stability > help for ib person day set matches snapshot 1`] = `
"USAGE
  ib person day set [flags]

DESCRIPTION
  Set a person's day availability status (vacation/sick/free/…). Requires --reason.
  Auth: requires login (any authenticated user).
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

FLAGS
  --person NUMBER    personId (required)
  --date DATE    Day YYYY-MM-DD (or today/yesterday/tomorrow) (required)
  --status STRING    personPvmStatusId or status name (see \`ib person day statuses\`) (required)
  --text STRING    Free-text note on the day row

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  personPvm save result | { dryRun:true, personId, date, wouldChange:{ status?, text? } } (with --dry-run)

ERRORS (stderr, exit non-zero)
  exit 4 (HTTP 400)  Missing --reason or unknown/ambiguous --status → supply --reason; check \`ib person day statuses\`
  exit 3 (HTTP 403)  Requires Admin or HR Admin on the active company → use an Admin/HR account
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Requires Admin or HR Admin (server-enforced) — Keikka Handler is NOT sufficient.
  - --status accepts an id or a name (resolved via \`ib person day statuses\`).
  - --reason is hard-required (exits 4 without it).
  - --dry-run is CLIENT-side (the save endpoint has no server X-Dry-Run guard): it previews wouldChange and never writes.
  - Read-merges the existing row so a re-set updates in place (no duplicate) and PRESERVES the existing vehicle assignment. It cannot CHANGE the vehicle — use \`ib driver assign\` for that (atomic).

SEE ALSO
  ib person day statuses, ib person day clear, ib driver assign

EXAMPLES
  ib person day set --person 555 --date tomorrow --status loma --reason 'kesäloma'
  ib person day set --person 555 --date 2026-06-10 --status 2 --dry-run --reason preview
"
`;

exports[`Help snapshots — contract stability > help for ib person day statuses matches snapshot 1`] = `
"USAGE
  ib person day statuses [flags]

DESCRIPTION
  List the day-status types (vacation/sick/free/…) for the active company
  Auth: requires login (any authenticated user).

FLAGS
