exports[`Help snapshots — contract stability > help for ib message daily set matches snapshot 1`] = `
"USAGE
  ib message daily set <boxId> [flags]

DESCRIPTION
  Write or clear a box's message for a date — the core daily-message write. The backend also broadcasts a dailyMessage:updated socket to every associated company.
  Auth: requires login (any authenticated user).
  Timezone: dates interpreted in active company timezone (Europe/Helsinki).

ARGUMENTS
  <boxId> NUMBER    Box whose message to set (required)

FLAGS
  --date DATE    Date the message applies to (required)
  --message STRING    Message text to store
  --clear BOOLEAN    Clear the message for the date (mutually exclusive with --message)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { success, ... }

ERRORS (stderr, exit non-zero)
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 4 (HTTP 400)  Validation error (bad date/ids/missing fields) → check the flags
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

NOTES
  - Exactly one of --message / --clear is required.
  - --dry-run is CLIENT-side (returns the would-be payload, sends nothing) — the dailyMessage routes have no server X-Dry-Run guard.

SEE ALSO
  ib message daily get

EXAMPLES
  ib message daily set 36 --date today --message "Asema kiinni klo 15" --reason "tiedote"
"
`;

