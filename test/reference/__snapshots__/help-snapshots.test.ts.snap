exports[`Help snapshots — contract stability > help for ib jerry admin request-cancel matches snapshot 1`] = `
"USAGE
  ib jerry admin request-cancel <requestId> [flags]

DESCRIPTION
  Cancel a non-terminal, non-accepted request (POST /api/admin/jerry-requests/:id/cancel). status → cancelled. Already cancelled/expired/accepted → 409 (an accepted request has a confirmed offer/keikka and is not cancellable here). System-admin only. Requires --reason.
  Permissions: requires isSystemAdmin.

ARGUMENTS
  <requestId> NUMBER    pumppuRequestId (required)

FLAGS
  --reason STRING    Audit-log reason (REQUIRED)

WRITE-SAFETY FLAGS
  --dry-run            Validate without persisting. Returns the would-be response.
  --idempotency-key K  Replay protection. Cached for 24h.
  --reason TEXT        Free-text justification. Stored in audit log.

GLOBAL FLAGS
  --endpoint URL  --request-id ID  --quiet  --verbose  --pretty  --json  --read-only  --company ID

OUTPUT (JSON, stdout)
  { success: true, status: 'cancelled' } or { dryRun: true, wouldUpdate: { pumppuRequestId, status } }

ERRORS (stderr, exit non-zero)
  exit 3 (HTTP 403)  Not a system admin     → use a system-admin token
  exit 4 (HTTP 409)  Wrong state            → request not in a cancellable state
  exit 2 (HTTP 401)  Token expired          → ib auth refresh
  exit 6 (HTTP 500)  Backend error          → retry with --verbose

EXAMPLES
  ib jerry admin request-cancel 41 --reason "customer request"
"
`;

