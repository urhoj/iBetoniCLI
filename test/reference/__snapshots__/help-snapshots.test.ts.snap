exports[`Help snapshots — contract stability > help for ib dev changelog list matches snapshot 1`] = `
"USAGE
  ib dev changelog list [flags]

DESCRIPTION
  List change entries with filters.
  Auth: requires login (any authenticated user).

FLAGS
  --month STRING    YYYY-MM
  --type STRING    feature|improvement|bugfix
  --area STRING    frontend|backend|cli|database|cicd
  --repo STRING    Repo/submodule
  --feedback NUMBER    linked feedback id
  --sentry STRING    linked Sentry issue short id
  --source STRING    human|routine
  --search STRING    Substring match over title/description/files/commitShas (deploy-gated)
  --status STRING    Substring match on the free-text status field, e.g. 'Deployed' (deploy-gated)
