{
  "name": "@ibetoni/cli",
  "version": "1.0.4",
  "description": "iBetoni CLI — AI-driven command-line interface for betoni.online",
  "type": "module",
  "bin": {
    "ib": "./dist/bin/ib.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/bin/ib.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint src test",
    "lint:fix": "cross-env ESLINT_USE_FLAT_CONFIG=false eslint --fix src test",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ibetoni/auth": "*",
    "@ibetoni/constants": "*",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
