{
  "name": "@ibetoni/cli",
  "version": "0.1.0-alpha",
  "description": "iBetoni CLI — AI-driven command-line interface for betoni.online",
  "type": "module",
  "bin": { "ib": "./dist/bin/ib.js" },
  "files": ["dist", "README.md"],
  "engines": { "node": ">=20.10.0" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/bin/ib.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "lint:fix": "eslint --fix src test",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "open": "^10.1.0",
    "undici": "^6.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "eslint": "^9.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  }
}
