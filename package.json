{
  "name": "@ibetoni/cli",
  "version": "1.1.11",
  "description": "iBetoni CLI — AI-driven command-line interface for betoni.online and betoniJerry",
  "type": "module",
  "bin": {
    "ib": "./dist/bin/ib.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "prebuild": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.json",
    "check:dist": "node scripts/check-dist-fresh.js",
    "dev": "tsx src/bin/ib.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src test",
    "lint:fix": "eslint --fix src test",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ibetoni/auth": "*",
    "@ibetoni/constants": "*",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.4",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
